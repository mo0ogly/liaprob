      "path": "/",
      "follow_redirects": true
    },
    {
      "id": "recog_unknown_l4_tcp",
      "layer": "L4_TCP",
      "matchers": [
        {
          "target": "banner",
          "match_type": "regex",
          "value": "(?:Basic|Digest) realm=\"NETGEAR ([a-zA-Z0-9\\-\\+]+)\\s*\"",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "Netgear Routers"
