    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "tls"
  ],
  "examples": [
    "CN=MAC000FE507A1F1,OU=M5IC,O=Mercury Security Products\\, LLC,L=Long Beach,ST=CA,C=US",
    "CN=MAC000FE508BC71,OU=EP-1502,O=Mercury Security Products\\, LLC,L=Long Beach,ST=CA,C=US",
