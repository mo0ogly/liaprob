{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-ripe_dns",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "RIPE_DNS",
  "taxonomy_name": "RIPE DNS",
  "vendor": "RIPE",
  "product": "DNS",
  "source": {
    "type": "recog",
    "file": "RIPE_DNS.json",
    "fingerprint_count": 1
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 1 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    53
  ],
  "probes": [
    {
      "id": "recog_ripe_dns_dns",
      "layer": "DNS",
      "matchers": [
        {
          "target": "dns_version",
          "match_type": "regex",
          "value": "^Atlas Anchor ([\\d\\.]+)$",
          "confidence_delta": 0.4,
          "version_extract": "^Atlas Anchor ([\\d\\.]+)$",
          "version_group": 1,
          "case_insensitive": true,
          "note": "Ripe ATLAS Anchor"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "dns"
  ],
  "examples": [
    "Atlas Anchor 0.1"
  ]
}