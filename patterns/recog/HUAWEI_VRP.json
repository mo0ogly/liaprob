  "probes": [
    {
      "id": "recog_huawei_vrp_snmp",
      "layer": "SNMP",
      "matchers": [
        {
          "target": "snmp_sysdescr",
          "match_type": "regex",
          "value": "VRP[^V]*Version ([\\d.]+) \\(([^\\s]+) (V\\d{3,3}R\\d{3,3}(?:C\\d{2,2})?(?:SPC\\d+|SPH\\d+|CP\\d+|HP\\d+)?)\\)",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "HUAWEI VRP"
        }
      ]
    },
    {
      "id": "recog_huawei_vrp_l4_tcp",
      "layer": "L4_TCP",
      "matchers": [
        {
          "target": "banner",
          "match_type": "regex",
          "value": "^HUAWEI.VRP.([\\d\\.]+)$",
          "confidence_delta": 0.4,
          "version_extract": "^HUAWEI.VRP.([\\d\\.]+)$",
          "version_group": 1,
          "case_insensitive": true,
          "note": "Huawei Versatile Routing Platform (VRP)"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
