{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-huawei_vrp",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "HUAWEI_VRP",
  "taxonomy_name": "Huawei VRP",
  "vendor": "Huawei",
  "product": "VRP",
  "source": {
    "type": "recog",
    "file": "HUAWEI_VRP.json",
    "fingerprint_count": 2
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 2 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    22,
    161
