{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-nlnet_labs_dnsd",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "NLNET_LABS_DNSD",
  "taxonomy_name": "NLnet Labs dnsd",
  "vendor": "NLnet Labs",
  "product": "dnsd",
  "source": {
    "type": "recog",
    "file": "NLNET_LABS_DNSD.json",
    "fingerprint_count": 1
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 1 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    53
  ],
  "probes": [
    {
      "id": "recog_nlnet_labs_dnsd_dns",
      "layer": "DNS",
      "matchers": [
        {
          "target": "dns_version",
          "match_type": "regex",
          "value": "^NSD ([\\d.]*(?:b\\d+)?)$",
          "confidence_delta": 0.4,
          "version_extract": "^NSD ([\\d.]*(?:b\\d+)?)$",
          "version_group": 1,
          "case_insensitive": true,
          "note": "NLnet Labs Name Server Daemon"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "dns"
  ],
  "cpe23_template": "cpe:/a:nlnetlabs:name_server_daemon:{version}",
  "examples": [
    "NSD 3.2.18",
    "NSD 4.0.0b5",
    "NSD 4",
    "NSD"
  ]
}