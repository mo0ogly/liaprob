{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-incognito_dns",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "INCOGNITO_DNS",
  "taxonomy_name": "Incognito DNS",
  "vendor": "Incognito",
  "product": "DNS",
  "source": {
    "type": "recog",
    "file": "INCOGNITO_DNS.json",
    "fingerprint_count": 1
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 1 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    53
  ],
  "probes": [
    {
      "id": "recog_incognito_dns_dns",
      "layer": "DNS",
      "matchers": [
        {
          "target": "dns_version",
          "match_type": "regex",
          "value": "^Incognito DNS Service ([\\d\\.]+) \\(built",
          "confidence_delta": 0.4,
          "version_extract": "^Incognito DNS Service ([\\d\\.]+) \\(built",
          "version_group": 1,
          "case_insensitive": true,
          "note": "Incognito DNS Service"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "dns"
  ],
  "examples": [
    "Incognito DNS Service 6.4.4.2 (built Aug 10 2015) [up=15d30902s, ser=9876]"
  ]
}