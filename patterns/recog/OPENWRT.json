{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-openwrt",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "OPENWRT",
  "taxonomy_name": "OpenWRT",
  "vendor": "OpenWRT",
  "product": "",
  "source": {
    "type": "recog",
    "file": "OPENWRT.json",
    "fingerprint_count": 1
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 1 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    443,
    8443
  ],
  "probes": [
    {
      "id": "recog_openwrt_tls_cert",
      "layer": "TLS_CERT",
      "matchers": [
        {
          "target": "tls_subject",
          "match_type": "regex",
          "value": "^CN=OpenWrt,L=Leipzig,ST=Saxony,C=DE$",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "OpenWRT WAP"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "tls"
  ],
  "examples": [
    "CN=OpenWrt,L=Leipzig,ST=Saxony,C=DE"
  ]
}