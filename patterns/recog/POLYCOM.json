          "case_insensitive": true,
          "note": "Polycom Soundpoint IP Telephone"
        }
      ],
      "method": "GET",
      "path": "/",
      "follow_redirects": true
    },
    {
      "id": "recog_polycom_l4_tcp",
      "layer": "L4_TCP",
