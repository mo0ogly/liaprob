{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-kong_gateway",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "KONG_GATEWAY",
  "taxonomy_name": "Kong Gateway",
  "vendor": "Kong",
  "product": "Gateway",
  "source": {
    "type": "recog",
    "file": "KONG_GATEWAY.json",
    "fingerprint_count": 2
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 2 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    80,
    443,
    8080,
    8443
  ],
  "probes": [
    {
      "id": "recog_kong_gateway_l7_http",
      "layer": "L7_HTTP",
      "matchers": [
        {
          "target": "header",
          "match_type": "regex",
          "value": "^kong/([\\d.]+)$",
          "confidence_delta": 0.4,
          "field": "server",
          "version_extract": "^kong/([\\d.]+)$",
          "version_group": 1,
          "case_insensitive": true,
          "note": "Kong Gateway"
        },
        {
          "target": "header",
          "match_type": "regex",
          "value": "^kong/([\\d.-]+)-enterprise-edition$",
          "confidence_delta": 0.4,
          "field": "server",
          "version_extract": "^kong/([\\d.-]+)-enterprise-edition$",
          "version_group": 1,
          "case_insensitive": true,
          "note": "Kong Gateway - Enterprise Edition"
        }
      ],
      "method": "GET",
      "path": "/",
      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "http"
  ],
  "cpe23_template": "cpe:/a:konghq:kong_gateway:{version}",
  "examples": [
    "kong/1.2.1",
    "kong/0.30-enterprise-edition",
    "kong/0.35-1-enterprise-edition"
  ]
}