{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-algo",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "ALGO",
  "taxonomy_name": "Algo",
  "vendor": "Algo",
  "product": "",
  "source": {
    "type": "recog",
    "file": "ALGO.json",
    "fingerprint_count": 1
  },
  "research": [
    {
