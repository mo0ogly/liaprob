          "match_type": "regex",
          "value": "^Qpopper \\(version (\\d+\\.\\d+\\.\\d+), modified by Sphera Technologies\\) at (.+) starting\\.",
          "confidence_delta": 0.4,
          "version_extract": "^Qpopper \\(version (\\d+\\.\\d+\\.\\d+), modified by Sphera Technologies\\) at (.+) starting\\.",
          "version_group": 1,
          "case_insensitive": true,
          "note": "Qpopper with Sphera mods"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "pop3"
  ],
  "examples": [
    "Qpopper (version 4.0.3, modified by Sphera Technologies) at domain starting.  <xxx@domain>"
  ]
}