{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-sphera_qpopper",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "SPHERA_QPOPPER",
  "taxonomy_name": "Sphera Qpopper",
  "vendor": "Sphera",
  "product": "Qpopper",
  "source": {
    "type": "recog",
    "file": "SPHERA_QPOPPER.json",
    "fingerprint_count": 1
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 1 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    110,
    995
  ],
  "probes": [
    {
      "id": "recog_sphera_qpopper_l4_tcp",
