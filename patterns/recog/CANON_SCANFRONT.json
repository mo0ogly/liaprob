          "note": "Canon ScanFront Simple"
        },
        {
          "target": "tls_subject",
          "match_type": "regex",
          "value": "^CN=ScanFront,OU=IMS,O=CANON ELECTRONICS INC\\.,L=Minato-ku,ST=Tokyo,C=JP$",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "Canon ScanFront Full"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "tls"
  ],
  "examples": [
    "CN=ScanFront",
    "CN=ScanFront,OU=IMS,O=CANON ELECTRONICS INC.,L=Minato-ku,ST=Tokyo,C=JP"
