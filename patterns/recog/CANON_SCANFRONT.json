{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-canon_scanfront",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "CANON_SCANFRONT",
  "taxonomy_name": "Canon ScanFront",
  "vendor": "Canon",
  "product": "ScanFront",
  "source": {
    "type": "recog",
    "file": "CANON_SCANFRONT.json",
    "fingerprint_count": 2
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 2 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    443,
    8443
