{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-ibm_httpd",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "IBM_HTTPD",
  "taxonomy_name": "IBM HTTPD",
  "vendor": "IBM",
  "product": "HTTPD",
  "source": {
    "type": "recog",
    "file": "IBM_HTTPD.json",
    "fingerprint_count": 2
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 2 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    80,
    443,
    8080,
    8443
  ],
  "probes": [
    {
      "id": "recog_ibm_httpd_l7_http",
      "layer": "L7_HTTP",
      "matchers": [
        {
          "target": "body",
          "match_type": "regex",
          "value": "^IBM HTTP Server$",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "IBM HTTP Server w/o Version"
        },
        {
          "target": "body",
          "match_type": "regex",
          "value": "^IBM HTTP Server ([0-9\\.]+)$",
          "confidence_delta": 0.4,
          "version_extract": "^IBM HTTP Server ([0-9\\.]+)$",
          "version_group": 1,
          "case_insensitive": true,
          "note": "IBM HTTP Server with Version"
        }
      ],
      "method": "GET",
      "path": "/",
      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "http"
  ],
  "examples": [
    "IBM HTTP Server",
    "IBM HTTP Server 8.5.5"
  ]
}