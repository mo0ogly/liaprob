{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-datamax",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "DATAMAX",
  "taxonomy_name": "Datamax",
  "vendor": "Datamax",
  "product": "",
  "source": {
    "type": "recog",
    "file": "DATAMAX.json",
    "fingerprint_count": 1
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 1 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    161
  ],
  "probes": [
    {
      "id": "recog_datamax_snmp",
      "layer": "SNMP",
      "matchers": [
        {
          "target": "snmp_sysdescr",
          "match_type": "regex",
          "value": "^Datamax Corporation I-Class (\\S+) Ver:(\\S+)",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "Datamax I-Class printer"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "snmp"
  ],
  "examples": [
    "Datamax Corporation I-Class 4208 Ver:08.01 01/14/2004 PN:83-2297-08B",
    "Datamax Corporation I-Class 4208 Ver:08.038 11/16/2004 PN:83-2297-08D8",
    "Datamax Corporation I-Class 4208 Ver:08.03R2 08/30/2007 PN:83-2297-08DR2"
  ]
}