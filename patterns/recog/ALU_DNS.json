{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-alu_dns",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "ALU_DNS",
  "taxonomy_name": "ALU DNS",
  "vendor": "ALU",
  "product": "DNS",
  "source": {
    "type": "recog",
    "file": "ALU_DNS.json",
    "fingerprint_count": 1
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 1 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    53
  ],
  "probes": [
    {
      "id": "recog_alu_dns_dns",
