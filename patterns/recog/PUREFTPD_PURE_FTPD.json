        {
          "target": "banner",
          "match_type": "regex",
          "value": "^-{9,10}(?:.*)\\s+Pure-FTPd\\s+(.*)-{9,10}",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "Pure-FTPd versions >= 1.0.14 - Config data can be zero or more of: [privsep] [TLS]"
        },
        {
          "target": "banner",
          "match_type": "regex",
          "value": "^(?:Welcome to )?Pure-FTPd\\.?$",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "Basic Pure-FTPd banner, no version"
        },
        {
          "target": "banner",
          "match_type": "regex",
          "value": "^=\\(.\\*.\\)=-\\.:\\. \\(\\( Welcome to PureFTPd (\\d+\\..+) \\)\\) \\.:\\.-=\\(.\\*.\\)=-",
          "confidence_delta": 0.4,
          "version_extract": "^=\\(.\\*.\\)=-\\.:\\. \\(\\( Welcome to PureFTPd (\\d+\\..+) \\)\\) \\.:\\.-=\\(.\\*.\\)=-",
          "version_group": 1,
          "case_insensitive": true,
          "note": "Older Pure-FTPd versions"
        }
      ]
    }
