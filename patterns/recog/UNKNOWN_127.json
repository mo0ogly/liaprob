      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "ftp"
  ],
  "examples": [
    "FTP server is ready.",
    "FTP Server ready.",
    "FTP Server Ready",
