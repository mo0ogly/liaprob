{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-raptor",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "RAPTOR",
  "taxonomy_name": "raptor",
  "vendor": "",
  "product": "raptor",
  "source": {
    "type": "recog",
    "file": "RAPTOR.json",
    "fingerprint_count": 2
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 2 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    25,
    587
  ],
  "probes": [
    {
      "id": "recog_raptor_l4_tcp",
      "layer": "L4_TCP",
      "matchers": [
        {
          "target": "banner",
          "match_type": "regex",
          "value": "^([^ ]{1,512}) Generic SMTP handler *$",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "Raptor Firewall (low confidence)"
        },
        {
          "target": "banner",
          "match_type": "regex",
          "value": "^503[ -]5\\.5\\.0 Not accepting any command except QUIT$",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "Raptor Firewall"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "generic",
    "smtp"
  ],
  "examples": [
    "foo.bar Generic SMTP handler",
    "503 5.5.0 Not accepting any command except QUIT"
  ]
}