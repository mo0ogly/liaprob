{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-vsftpd_project_vsftpd",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "VSFTPD_PROJECT_VSFTPD",
  "taxonomy_name": "vsFTPd Project vsFTPd",
  "vendor": "vsFTPd Project",
  "product": "vsFTPd",
  "source": {
    "type": "recog",
    "file": "VSFTPD_PROJECT_VSFTPD.json",
    "fingerprint_count": 3
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 3 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    21
  ],
  "probes": [
    {
      "id": "recog_vsftpd_project_vsftpd_l4_tcp",
      "layer": "L4_TCP",
      "matchers": [
        {
          "target": "banner",
          "match_type": "regex",
          "value": "^\\(vsFTPd (\\d+\\..+)\\)(?: (.+))?$",
          "confidence_delta": 0.4,
          "version_extract": "^\\(vsFTPd (\\d+\\..+)\\)(?: (.+))?$",
          "version_group": 1,
          "case_insensitive": true,
          "note": "vsFTPd (Very Secure FTP Daemon)"
        },
        {
          "target": "banner",
          "match_type": "regex",
          "value": "^ready, dude \\(vsFTPd (\\d+\\..+): beat me, break me\\)$",
          "confidence_delta": 0.4,
          "version_extract": "^ready, dude \\(vsFTPd (\\d+\\..+): beat me, break me\\)$",
          "version_group": 1,
          "case_insensitive": true,
          "note": "vsFTPd (Very Secure FTP Daemon) - break me variant"
        },
        {
          "target": "banner",
          "match_type": "regex",
          "value": "^OOPS: .*vsftp",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "vsFTPd (Very Secure FTP Daemon) error message"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "ftp"
  ],
  "cpe23_template": "cpe:/a:vsftpd_project:vsftpd:{version}",
  "examples": [
    "(vsFTPd 1.1.3) host",
    "(vsFTPd 2.0.5)",
    "ready, dude (vsFTPd 1.1.0: beat me, break me)",
    "OOPS: vsftpd: root is not mounted.",
    "OOPS: cannot read user list file:/etc/vsftpd.user_list"
  ]
}