        },
        {
          "target": "banner",
          "match_type": "regex",
          "value": "^ESMTP - WinRoute Pro ([^ ]+\\.[^ ]+) *(?: #\\d)? ?.?((?:\\w\\w\\w, \\d+ \\w\\w\\w \\d\\d\\d\\d [\\d:]+ [-+]\\d\\d\\d\\d)?)$",
          "confidence_delta": 0.4,
          "version_extract": "^ESMTP - WinRoute Pro ([^ ]+\\.[^ ]+) *(?: #\\d)? ?.?((?:\\w\\w\\w, \\d+ \\w\\w\\w \\d\\d\\d\\d [\\d:]+ [-+]\\d\\d\\d\\d)?)$",
          "version_group": 1,
          "case_insensitive": true,
          "note": "WinRoute Pro w/o hostname"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "smtp"
