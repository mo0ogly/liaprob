  "vendor": "",
  "product": "",
  "source": {
    "type": "recog",
    "file": "UNKNOWN.json",
    "fingerprint_count": 2
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
