      "method": "GET",
      "path": "/",
      "follow_redirects": true
    },
    {
      "id": "recog_unknown_l4_tcp",
      "layer": "L4_TCP",
      "matchers": [
        {
          "target": "banner",
          "match_type": "regex",
          "value": "(?i)^(?:Basic|Digest).*realm=\"TiVo DVR\"",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "Tivo DVR"
        }
      ]
