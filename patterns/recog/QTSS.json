{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-qtss",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "QTSS",
  "taxonomy_name": "QTSS",
  "vendor": "",
  "product": "QTSS",
  "source": {
    "type": "recog",
    "file": "QTSS.json",
    "fingerprint_count": 2
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 2 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    80,
    443,
    8080,
    8443
  ],
  "probes": [
    {
      "id": "recog_qtss_l7_http",
      "layer": "L7_HTTP",
      "matchers": [
        {
          "target": "header",
          "match_type": "regex",
          "value": "^QTSS\\/([\\d\\.]+) \\(Build\\/[\\d\\.]+; Platform\\/MacOSX; Release\\/Panther",
          "confidence_delta": 0.4,
          "field": "server",
          "version_extract": "^QTSS\\/([\\d\\.]+) \\(Build\\/[\\d\\.]+; Platform\\/MacOSX; Release\\/Panther",
          "version_group": 1,
          "case_insensitive": true,
          "note": "QTSS on OS X 10.3"
        },
        {
          "target": "header",
          "match_type": "regex",
          "value": "^QTSS\\/([\\d\\.]+) \\(Build\\/[\\d\\.]+; Platform\\/MacOSX; Release\\/Mac OS X",
          "confidence_delta": 0.4,
          "field": "server",
          "version_extract": "^QTSS\\/([\\d\\.]+) \\(Build\\/[\\d\\.]+; Platform\\/MacOSX; Release\\/Mac OS X",
          "version_group": 1,
          "case_insensitive": true,
          "note": "QTSS OS X"
        }
      ],
      "method": "GET",
      "path": "/",
      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "http"
  ],
  "cpe23_template": "cpe:/o:apple:mac_os_x:10.3",
  "examples": [
    "QTSS/5.0 (Build/452; Platform/MacOSX; Release/Panther; )",
    "QTSS/5.0.3.3 (Build/452.22.4; Platform/MacOSX; Release/Panther; Update/Security; )",
    "QTSS/6.1.0 (Build/532; Platform/MacOSX; Release/Mac OS X Server; )"
  ]
}