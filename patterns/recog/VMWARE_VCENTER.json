{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-vmware_vcenter",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "VMWARE_VCENTER",
  "taxonomy_name": "VMware vCenter",
  "vendor": "VMware",
  "product": "vCenter",
  "source": {
    "type": "recog",
    "file": "VMWARE_VCENTER.json",
    "fingerprint_count": 2
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 2 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    80,
    443,
    8080,
    8443
  ],
  "probes": [
    {
      "id": "recog_vmware_vcenter_l7_http",
      "layer": "L7_HTTP",
      "matchers": [
        {
          "target": "body",
          "match_type": "regex",
          "value": "^\" \\+ ID_VC_Welcome \\+ \"$",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "VMware vCenter"
        }
      ],
      "method": "GET",
      "path": "/",
      "follow_redirects": true
    },
    {
      "id": "recog_vmware_vcenter_tls_cert",
      "layer": "TLS_CERT",
      "matchers": [
        {
          "target": "tls_issuer",
          "match_type": "regex",
          "value": "^CN=CA,OU=VMware Engineering,O=vCenter,ST=California,C=US$",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "VMware vCenter"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "http",
    "tls"
  ],
  "cpe23_template": "cpe:/a:vmware:vcenter_server:-",
  "examples": [
    "\" + ID_VC_Welcome + \"",
    "CN=CA,OU=VMware Engineering,O=vCenter,ST=California,C=US"
  ]
}