{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-apple_open_directory",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "APPLE_OPEN_DIRECTORY",
  "taxonomy_name": "Apple Open Directory",
  "vendor": "Apple",
  "product": "Open Directory",
  "source": {
    "type": "recog",
    "file": "APPLE_OPEN_DIRECTORY.json",
    "fingerprint_count": 1
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 1 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    110,
    995
  ],
  "probes": [
    {
      "id": "recog_apple_open_directory_l4_tcp",
      "layer": "L4_TCP",
      "matchers": [
        {
          "target": "banner",
          "match_type": "regex",
          "value": "^ApplePasswordServer ([\\d\\.]+) password",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "Apple Open Directory"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "pop3"
  ],
  "cpe23_template": "cpe:/o:apple:mac_os_x:{os.version}",
  "examples": [
    "ApplePasswordServer 10.6.0.0 password server at 10.2.90.228 ready.",
    "ApplePasswordServer 10.5.0.1 password serv"
  ]
}