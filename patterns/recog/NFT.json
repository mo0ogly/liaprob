{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-nft",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "NFT",
  "taxonomy_name": "NFT",
  "vendor": "NFT",
  "product": "",
  "source": {
    "type": "recog",
    "file": "NFT.json",
    "fingerprint_count": 1
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 1 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    80,
    443,
    8080,
    8443
  ],
  "probes": [
    {
      "id": "recog_nft_l7_http",
      "layer": "L7_HTTP",
      "matchers": [
        {
          "target": "body",
          "match_type": "regex",
          "value": "^NFT S7 - DALI-Gateway\\(Ethernet\\)$",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "NFT DALI S7 Ethernet Module"
        }
      ],
      "method": "GET",
      "path": "/",
      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "http"
  ],
  "examples": [
    "NFT S7 - DALI-Gateway(Ethernet)"
  ]
}