          "value": "^FreSSH\\.(.*)$",
          "confidence_delta": 0.4,
          "version_extract": "^FreSSH\\.(.*)$",
          "version_group": 1,
          "case_insensitive": true,
          "note": "FreSSH"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "ssh"
  ],
  "examples": [
    "FreSSH.0.8"
