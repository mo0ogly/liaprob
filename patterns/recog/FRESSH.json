{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-fressh",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "FRESSH",
  "taxonomy_name": "FreSSH",
  "vendor": "",
  "product": "FreSSH",
  "source": {
    "type": "recog",
    "file": "FRESSH.json",
    "fingerprint_count": 1
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 1 Recog XML fingerprints",
