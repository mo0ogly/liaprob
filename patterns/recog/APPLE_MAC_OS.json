{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-apple_mac_os",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "APPLE_MAC_OS",
  "taxonomy_name": "Apple Mac OS",
  "vendor": "Apple",
  "product": "Mac OS",
  "source": {
    "type": "recog",
    "file": "APPLE_MAC_OS.json",
    "fingerprint_count": 1
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 1 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    80,
    443
  ],
  "probes": [
    {
      "id": "recog_apple_mac_os_l4_tcp",
      "layer": "L4_TCP",
      "matchers": [
        {
          "target": "banner",
          "match_type": "regex",
          "value": "(?i)^(?:Apple )?Mac OS ([7-9](?:\\.\\d+?)*?)$",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "Mac OS 9"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "generic"
  ],
  "cpe23_template": "cpe:/o:apple:macos:{os.version}",
  "examples": [
    "Mac OS 9",
    "Mac OS 9.0.5"
  ]
}