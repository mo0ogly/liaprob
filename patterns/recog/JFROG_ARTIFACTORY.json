{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-jfrog_artifactory",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "JFROG_ARTIFACTORY",
  "taxonomy_name": "JFrog Artifactory",
  "vendor": "JFrog",
  "product": "Artifactory",
  "source": {
    "type": "recog",
    "file": "JFROG_ARTIFACTORY.json",
    "fingerprint_count": 1
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 1 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    80,
    443,
    8080,
    8443
  ],
  "probes": [
    {
      "id": "recog_jfrog_artifactory_l7_http",
      "layer": "L7_HTTP",
      "matchers": [
        {
          "target": "header",
          "match_type": "regex",
          "value": "^Artifactory/([\\d.]+)$",
          "confidence_delta": 0.4,
          "field": "server",
          "version_extract": "^Artifactory/([\\d.]+)$",
          "version_group": 1,
          "case_insensitive": true,
          "note": "JFrog’s Artifactory repository management"
        }
      ],
      "method": "GET",
      "path": "/",
      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "http"
  ],
  "cpe23_template": "cpe:/a:jfrog:artifactory:{version}",
  "examples": [
    "Artifactory/4.16.0"
  ]
}