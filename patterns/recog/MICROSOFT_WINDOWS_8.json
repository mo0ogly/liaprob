{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-microsoft_windows_8",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "MICROSOFT_WINDOWS_8",
  "taxonomy_name": "Microsoft Windows 8",
  "vendor": "Microsoft",
  "product": "Windows 8",
  "source": {
    "type": "recog",
    "file": "MICROSOFT_WINDOWS_8.json",
    "fingerprint_count": 3
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 3 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    80,
    161,
    443,
    8080,
    8443
  ],
  "probes": [
    {
      "id": "recog_microsoft_windows_8_l7_http",
      "layer": "L7_HTTP",
      "matchers": [
        {
          "target": "header",
          "match_type": "regex",
          "value": "^Microsoft-Windows/6.2 UPnP/(?:\\S+) UPnP-Device-Host/(?:\\S+)$",
          "confidence_delta": 0.4,
          "field": "server",
          "case_insensitive": true,
          "note": "Windows 8 or Windows Server 2012 with unknown UPnP components"
        }
      ],
      "method": "GET",
      "path": "/",
      "follow_redirects": true
    },
    {
      "id": "recog_microsoft_windows_8_snmp",
      "layer": "SNMP",
      "matchers": [
        {
          "target": "snmp_sysdescr",
          "match_type": "regex",
          "value": "^Hardware: \\S+64.*Software: Windows Version 6.2 \\(Build 9200",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "Windows 8 on x86_64"
        },
        {
          "target": "snmp_sysdescr",
          "match_type": "regex",
          "value": "^Hardware: x86.*Software: Windows Version 6.2 \\(Build 9200",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "Windows 8 on x86"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "http",
    "snmp"
  ],
  "cpe23_template": "cpe:/o:microsoft:windows_8:-",
  "examples": [
    "Hardware: Intel64 Family 6 Model 2 Stepping 3 AT/AT COMPATIBLE - Software: Windows Version 6.2 (Build 9200 Multiprocessor Free)",
    "Hardware: x86 Family 6 Model 2 Stepping 3 AT/AT COMPATIBLE - Software: Windows Version 6.2 (Build 9200 Multiprocessor Free)"
  ]
}