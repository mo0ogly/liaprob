{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-cisco_nam",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "CISCO_NAM",
  "taxonomy_name": "Cisco NAM",
  "vendor": "Cisco",
  "product": "NAM",
  "source": {
    "type": "recog",
    "file": "CISCO_NAM.json",
    "fingerprint_count": 2
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 2 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    161
  ],
  "probes": [
    {
      "id": "recog_cisco_nam_snmp",
      "layer": "SNMP",
      "matchers": [
        {
          "target": "snmp_sysdescr",
          "match_type": "regex",
          "value": "^(?:Cisco )?Network Analysis Module \\(WS-[^\\)]+\\), Version ([^,\\s]+)",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "Cisco Catalyst Network Analysis Module - version variant"
        },
        {
          "target": "snmp_sysdescr",
          "match_type": "regex",
          "value": "^(?:Cisco )?Network Analysis Module \\(WS-([^\\-]+)-NAM\\)$",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "Cisco Catalyst Network Analysis Module"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "snmp"
  ],
  "cpe23_template": "cpe:/o:cisco:network_analysis_module_software:{os.version}",
