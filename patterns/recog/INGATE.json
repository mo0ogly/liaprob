{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-ingate",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "INGATE",
  "taxonomy_name": "Ingate",
  "vendor": "Ingate",
  "product": "",
  "source": {
    "type": "recog",
    "file": "INGATE.json",
    "fingerprint_count": 1
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 1 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    5060
  ],
  "probes": [
    {
      "id": "recog_ingate_l4_tcp",
      "layer": "L4_TCP",
      "matchers": [
        {
          "target": "banner",
          "match_type": "regex",
          "value": "^(?:SIParator|Ingate-Firewall)/(\\S+)$",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "Ingate SIParator Firewall"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "sip"
  ],
  "examples": [
    "Ingate-Firewall/5.0.10",
    "SIParator/6.0.4"
  ]
}