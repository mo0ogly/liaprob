{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-zte",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "ZTE",
  "taxonomy_name": "ZTE",
  "vendor": "ZTE",
  "product": "",
  "source": {
    "type": "recog",
    "file": "ZTE.json",
    "fingerprint_count": 1
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 1 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    80,
    443,
    8080,
    8443
  ],
  "probes": [
    {
      "id": "recog_zte_l7_http",
      "layer": "L7_HTTP",
      "matchers": [
        {
          "target": "header",
          "match_type": "regex",
          "value": "^((?:Mini|ZTE) web server) ([\\d.]+) ZTE corp \\d{4}\\.$",
          "confidence_delta": 0.4,
          "field": "server",
          "version_extract": "^((?:Mini|ZTE) web server) ([\\d.]+) ZTE corp \\d{4}\\.$",
          "version_group": 2,
          "case_insensitive": true,
          "note": "Assorted ZTE CPE device web server"
        }
      ],
      "method": "GET",
      "path": "/",
      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "http"
  ],
  "examples": [
    "Mini web server 1.0 ZTE corp 2005.",
    "ZTE web server 1.0 ZTE corp 2015."
  ]
}