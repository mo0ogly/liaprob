{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-ibm_dns",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "IBM_DNS",
  "taxonomy_name": "IBM DNS",
  "vendor": "IBM",
  "product": "DNS",
  "source": {
    "type": "recog",
    "file": "IBM_DNS.json",
    "fingerprint_count": 1
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 1 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    53
  ],
  "probes": [
    {
      "id": "recog_ibm_dns_dns",
      "layer": "DNS",
      "matchers": [
        {
          "target": "dns_version",
          "match_type": "regex",
          "value": "^Q9-[^\\-]-(.*)$",
          "confidence_delta": 0.4,
          "version_extract": "^Q9-[^\\-]-(.*)$",
          "version_group": 1,
          "case_insensitive": true,
          "note": "Quad9 Resolver"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "dns"
  ],
  "examples": [
    "Q9-P-6.0"
  ]
}