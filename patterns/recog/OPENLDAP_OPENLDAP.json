{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-openldap_openldap",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "OPENLDAP_OPENLDAP",
  "taxonomy_name": "OpenLDAP OpenLDAP",
  "vendor": "OpenLDAP",
  "product": "OpenLDAP",
  "source": {
    "type": "recog",
    "file": "OPENLDAP_OPENLDAP.json",
    "fingerprint_count": 1
