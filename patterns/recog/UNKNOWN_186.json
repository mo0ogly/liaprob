{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-unknown",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "UNKNOWN",
  "taxonomy_name": "",
  "vendor": "",
  "product": "",
  "source": {
    "type": "recog",
    "file": "UNKNOWN.json",
    "fingerprint_count": 1
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 1 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    80,
    443
