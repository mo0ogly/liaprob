          "match_type": "regex",
          "value": "^(?:Basic|Digest) .*realm=\"(?:(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.){3}(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\"",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "Ignore realms with an IPv4 address -- assert nothing"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "generic"
  ],
  "examples": [
    "Basic realm=\"192.168.0.1\"",
    "Digest qop=\"auth\", realm=\"172.16.0.1\", nonce=\"AAAAAAAAAAAAAP//DwHpM0IvM78=\", algorithm=\"MD5\""
