{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-extrahop_discover",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "EXTRAHOP_DISCOVER",
  "taxonomy_name": "ExtraHop Discover",
  "vendor": "ExtraHop",
  "product": "Discover",
  "source": {
    "type": "recog",
    "file": "EXTRAHOP_DISCOVER.json",
    "fingerprint_count": 1
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 1 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    443,
    8443
  ],
  "probes": [
    {
      "id": "recog_extrahop_discover_tls_cert",
      "layer": "TLS_CERT",
      "matchers": [
        {
          "target": "tls_subject",
          "match_type": "regex",
          "value": "^CN=extrahop,OU=extrahop\\.com,O=ExtraHop,C=US$",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "ExtraHop Appliance"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "tls"
  ],
  "examples": [
    "CN=extrahop,OU=extrahop.com,O=ExtraHop,C=US"
  ]
}