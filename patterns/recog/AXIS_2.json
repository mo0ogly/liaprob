{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-axis",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "AXIS",
  "taxonomy_name": "Axis",
  "vendor": "Axis",
  "product": "",
  "source": {
    "type": "recog",
    "file": "AXIS.json",
    "fingerprint_count": 1
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 1 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    161
  ],
  "probes": [
    {
      "id": "recog_axis_snmp",
      "layer": "SNMP",
      "matchers": [
        {
          "target": "snmp_sysdescr",
          "match_type": "regex",
          "value": "(?i)^AXIS (.*server).*(?:v|Version:\\s*)([\\d\\.]+)",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "AXIS Network Print Server"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "snmp"
  ],
  "examples": [
    "AXIS 5470e Network Print Server V6.21 Dec  5 2000",
    "AXIS 70U Network Document Server,Version: 1.08",
    "AXIS 540/542 Print Server V5.43 Feb 2 1998",
    "AXIS 560Print serverV5.36 Jul 7 1997",
    "AXIS OfficeBasic USB Network Print Server V7.03 Feb 14 2005",
    "AXIS PrintPoint 560/100 Print server V5.39 Dec 12 1997",
    "Axis NPS 550R Printer Server V4.11 Mar 1 1994",
    "Axis NPS 550RPrint serverV5.22 Oct 07 1996"
  ]
}