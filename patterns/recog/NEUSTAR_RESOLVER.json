          "case_insensitive": true,
          "note": "Neustar UltraDNS TLD Platform"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "dns"
  ],
  "examples": [
