{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-neustar_resolver",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "NEUSTAR_RESOLVER",
  "taxonomy_name": "Neustar Resolver",
  "vendor": "Neustar",
  "product": "Resolver",
  "source": {
    "type": "recog",
    "file": "NEUSTAR_RESOLVER.json",
    "fingerprint_count": 2
