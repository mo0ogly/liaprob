{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-cisco_ssh",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "CISCO_SSH",
  "taxonomy_name": "Cisco SSH",
  "vendor": "Cisco",
  "product": "SSH",
  "source": {
    "type": "recog",
    "file": "CISCO_SSH.json",
    "fingerprint_count": 2
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 2 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    22
  ],
  "probes": [
    {
      "id": "recog_cisco_ssh_l4_tcp",
      "layer": "L4_TCP",
      "matchers": [
        {
          "target": "banner",
          "match_type": "regex",
          "value": "^Cisco-(.*)$",
          "confidence_delta": 0.4,
          "version_extract": "^Cisco-(.*)$",
          "version_group": 1,
          "case_insensitive": true,
          "note": "Cisco SSH banner (could be IOS or PIX), The version always seems to be 1.25"
        },
        {
          "target": "banner",
          "match_type": "regex",
          "value": "^CISCO_WLC$",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "SSH banner from a Cisco WLC (WLC)"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "ssh"
  ],
  "cpe23_template": "cpe:/o:cisco:ios:-",
  "examples": [
    "Cisco-1.25",
    "CISCO_WLC"
  ]
}