{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-unknown",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "UNKNOWN",
  "taxonomy_name": "",
  "vendor": "",
  "product": "",
  "source": {
    "type": "recog",
    "file": "UNKNOWN.json",
    "fingerprint_count": 1
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 1 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    443,
    8443
  ],
  "probes": [
    {
      "id": "recog_unknown_tls_cert",
      "layer": "TLS_CERT",
      "matchers": [
        {
          "target": "tls_issuer",
          "match_type": "regex",
          "value": "^CN=DigiCert SHA2 (?:Extended Validation|High Assurance) Server CA,OU=www.digicert.com,O=DigiCert Inc,C=US$",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "DigiCert SHA2 EV - generic -- assert nothing."
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "tls"
  ],
  "examples": [
    "CN=DigiCert SHA2 Extended Validation Server CA,OU=www.digicert.com,O=DigiCert Inc,C=US",
    "CN=DigiCert SHA2 High Assurance Server CA,OU=www.digicert.com,O=DigiCert Inc,C=US"
  ]
}