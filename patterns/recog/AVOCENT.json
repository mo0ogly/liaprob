        {
          "target": "snmp_sysdescr",
          "match_type": "regex",
          "value": "^(ESP-\\d+) MI V(\\S+)$",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "Avocent ESP Serial Port"
        }
      ]
    },
    {
      "id": "recog_avocent_tls_cert",
      "layer": "TLS_CERT",
      "matchers": [
        {
          "target": "tls_subject",
          "match_type": "regex",
          "value": "^CN=avocent.com,OU=AESS,O=Avocent,L=Sunrise,ST=FL,C=US$",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "Avocent KVM"
