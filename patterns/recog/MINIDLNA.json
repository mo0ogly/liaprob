{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-minidlna",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "MINIDLNA",
  "taxonomy_name": "MiniDLNA",
  "vendor": "",
  "product": "MiniDLNA",
  "source": {
    "type": "recog",
    "file": "MINIDLNA.json",
    "fingerprint_count": 1
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 1 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    80,
    443,
    8080,
    8443
  ],
  "probes": [
    {
      "id": "recog_minidlna_l7_http",
      "layer": "L7_HTTP",
      "matchers": [
        {
          "target": "header",
          "match_type": "regex",
          "value": "^[^/]+/(\\S+) DLNADOC/\\S+ UPnP/\\S+ MiniDLNA/(\\S+)$",
          "confidence_delta": 0.4,
          "field": "server",
          "version_extract": "^[^/]+/(\\S+) DLNADOC/\\S+ UPnP/\\S+ MiniDLNA/(\\S+)$",
          "version_group": 2,
          "case_insensitive": true,
          "note": "DLNADOC UPnP Server"
        }
      ],
      "method": "GET",
      "path": "/",
      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "http"
  ],
  "cpe23_template": "cpe:/o:linux:linux_kernel:{os.version}",
  "examples": [
    "Debian/4.0r8 DLNADOC/1.50 UPnP/1.0 MiniDLNA/1.0",
    "FreeBSD/8.2-RELEASE-p4 DLNADOC/1.50 UPnP/1.0 MiniDLNA/1.0.24",
    "Linux/2.6.36+ DLNADOC/1.50 UPnP/1.0 MiniDLNA/1.0"
  ]
}