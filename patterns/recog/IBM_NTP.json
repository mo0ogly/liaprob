{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-ibm_ntp",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "IBM_NTP",
  "taxonomy_name": "IBM NTP",
  "vendor": "IBM",
  "product": "NTP",
  "source": {
    "type": "recog",
    "file": "IBM_NTP.json",
    "fingerprint_count": 1
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 1 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    80,
    443
  ],
  "probes": [
    {
      "id": "recog_ibm_ntp_l4_tcp",
      "layer": "L4_TCP",
      "matchers": [
        {
          "target": "banner",
          "match_type": "regex",
          "value": "system=\"UNIX/AIX\"",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "AIX with NTP enabled, no processor/version"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "generic"
  ],
  "cpe23_template": "cpe:/o:ibm:aix:-",
  "examples": [
    "system=\"UNIX/AIX\", leap=00, stratum=3, rootdelay=2.000,"
  ]
}