  "probes": [
    {
      "id": "recog_kubernetes_kubernetes_l4_tcp",
      "layer": "L4_TCP",
      "matchers": [
        {
          "target": "banner",
          "match_type": "regex",
          "value": "^(?:Basic|Digest) realm=\"kubernetes-master\"",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "Kubernetes master nodes"
        }
      ]
    },
    {
      "id": "recog_kubernetes_kubernetes_tls_cert",
      "layer": "TLS_CERT",
      "matchers": [
        {
          "target": "tls_subject",
          "match_type": "regex",
          "value": "^CN=kube-apiserver$",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "Kubernetes api-server default certificate"
        },
        {
          "target": "tls_subject",
          "match_type": "regex",
          "value": "^CN=kubernetes-master$",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "Kubernetes Control Plane (formerly master) default certificate"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "generic",
    "tls"
  ],
  "cpe23_template": "cpe:/a:kubernetes:kubernetes:-",
  "examples": [
