{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-cisco_telepresence",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "CISCO_TELEPRESENCE",
  "taxonomy_name": "Cisco TelePresence",
  "vendor": "Cisco",
  "product": "TelePresence",
  "source": {
    "type": "recog",
    "file": "CISCO_TELEPRESENCE.json",
    "fingerprint_count": 2
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 2 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    21,
    443,
    8443
  ],
  "probes": [
    {
      "id": "recog_cisco_telepresence_l4_tcp",
      "layer": "L4_TCP",
      "matchers": [
        {
          "target": "banner",
          "match_type": "regex",
          "value": "^Welcome to the (?:Cisco )?(?:TelePresence) ([a-zA-Z\\s]*?) ((?:MSE )?\\d+), version (\\d+.\\d+\\(\\d+.\\d+\\)).*?",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "Cisco TelePresence"
        }
      ]
    },
    {
      "id": "recog_cisco_telepresence_tls_cert",
      "layer": "TLS_CERT",
      "matchers": [
        {
          "target": "tls_subject",
          "match_type": "regex",
          "value": "^CN=TANDBERG,OU=R&D,O=TANDBERG ASA,L=Lysaker,ST=Askerhus,C=NO$",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "Cisco (TANDBERG) TelePresence"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "ftp",
    "tls"
  ],
  "examples": [
    "Welcome to the Cisco TelePresence AM GW 3610, version 1.1(1.34)",
    "Welcome to the Cisco TelePresence IP GW 3510, version 2.0(3.32)",
    "Welcome to the Cisco TelePresence MCU 4210, version 4.3(2.18)",
    "Welcome to the Cisco TelePresence MCU MSE 8420, version 4.3(1.68)",
    "Welcome to the Telepresence Server 7010, version 2.1(1.18)",
    "CN=TANDBERG,OU=R&D,O=TANDBERG ASA,L=Lysaker,ST=Askerhus,C=NO"
  ]
}