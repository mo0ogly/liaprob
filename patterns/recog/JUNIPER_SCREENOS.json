{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-juniper_screenos",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "JUNIPER_SCREENOS",
  "taxonomy_name": "Juniper ScreenOS",
  "vendor": "Juniper",
  "product": "ScreenOS",
  "source": {
    "type": "recog",
    "file": "JUNIPER_SCREENOS.json",
    "fingerprint_count": 2
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 2 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    23,
    161
  ],
  "probes": [
    {
      "id": "recog_juniper_screenos_snmp",
      "layer": "SNMP",
      "matchers": [
        {
          "target": "snmp_sysdescr",
          "match_type": "regex",
          "value": "^NetScreen-([\\w]+) version ([\\w.]+) \\(SN: [\\d]+, Firewall\\+VPN\\)$",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "Juniper NetScreen ScreenOS Firewall"
        }
      ]
    },
    {
      "id": "recog_juniper_screenos_l4_tcp",
      "layer": "L4_TCP",
      "matchers": [
        {
          "target": "banner",
          "match_type": "regex",
          "value": "^Remote Management Console\\r\\nlogin:\\s*$",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "Juniper Netscreen"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "telnet",
    "snmp"
  ],
  "cpe23_template": "cpe:/o:juniper:screenos:{os.version}",
