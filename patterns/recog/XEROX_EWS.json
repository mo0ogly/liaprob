{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-xerox_ews",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "XEROX_EWS",
  "taxonomy_name": "Xerox EWS",
  "vendor": "Xerox",
  "product": "EWS",
  "source": {
    "type": "recog",
    "file": "XEROX_EWS.json",
    "fingerprint_count": 1
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 1 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    80,
    443,
    8080,
    8443
  ],
  "probes": [
    {
      "id": "recog_xerox_ews_l7_http",
      "layer": "L7_HTTP",
      "matchers": [
        {
          "target": "header",
          "match_type": "regex",
          "value": "^EWS-NIC\\d/(\\S+)$",
          "confidence_delta": 0.4,
          "field": "server",
          "version_extract": "^EWS-NIC\\d/(\\S+)$",
          "version_group": 1,
          "case_insensitive": true,
          "note": "Xerox Embedded Web Server (EWS)"
        }
      ],
      "method": "GET",
      "path": "/",
      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "http"
  ],
  "examples": [
    "EWS-NIC3/6.31",
    "EWS-NIC4/13.40",
    "EWS-NIC4/13.39"
  ]
}