{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-tnftpd",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "TNFTPD",
  "taxonomy_name": "tnftpd",
  "vendor": "",
  "product": "tnftpd",
  "source": {
    "type": "recog",
    "file": "TNFTPD.json",
    "fingerprint_count": 1
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 1 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    21
  ],
  "probes": [
    {
      "id": "recog_tnftpd_l4_tcp",
      "layer": "L4_TCP",
      "matchers": [
        {
          "target": "banner",
          "match_type": "regex",
          "value": "^(\\S{1,512})\\s{1,8}FTP Server \\(tnftpd (.*)\\) ready\\.?$",
          "confidence_delta": 0.4,
          "version_extract": "^(\\S{1,512})\\s{1,8}FTP Server \\(tnftpd (.*)\\) ready\\.?$",
          "version_group": 2,
          "case_insensitive": true,
          "note": "Simple tnftpd banner with a version"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "ftp"
  ],
  "examples": [
    "example.com FTP server (tnftpd 20061217) ready."
  ]
}