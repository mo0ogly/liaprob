          "case_insensitive": true,
          "note": "IBM WebSphere"
        }
      ],
      "method": "GET",
      "path": "/",
      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "http"
  ],
  "cpe23_template": "cpe:/a:ibm:websphere:{version}",
