{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-ibm_websphere",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "IBM_WEBSPHERE",
  "taxonomy_name": "IBM WebSphere",
  "vendor": "IBM",
  "product": "WebSphere",
  "source": {
    "type": "recog",
    "file": "IBM_WEBSPHERE.json",
    "fingerprint_count": 1
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 1 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    80,
    443,
    8080,
    8443
