      ],
      "method": "GET",
      "path": "/",
      "follow_redirects": true
    },
    {
      "id": "recog_netapp_data_ontap_l4_tcp",
      "layer": "L4_TCP",
      "matchers": [
        {
          "target": "banner",
          "match_type": "regex",
          "value": "system=\"Data ONTAP/+(\\S+)\"",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "NetApp file servers"
        },
        {
          "target": "banner",
          "match_type": "regex",
          "value": "^Data ONTAP SSH [\\d\\.]+$",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "SSH NetApp appliances"
        },
        {
          "target": "banner",
          "match_type": "regex",
          "value": "^Data ONTAP",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "A NetApp apliance"
        }
      ]
    },
    {
      "id": "recog_netapp_data_ontap_snmp",
      "layer": "SNMP",
      "matchers": [
        {
          "target": "snmp_sysdescr",
          "match_type": "regex",
