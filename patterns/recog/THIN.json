{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-thin",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "THIN",
  "taxonomy_name": "Thin",
  "vendor": "",
  "product": "Thin",
  "source": {
    "type": "recog",
    "file": "THIN.json",
    "fingerprint_count": 1
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 1 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    80,
    443,
    8080,
    8443
  ],
  "probes": [
    {
      "id": "recog_thin_l7_http",
      "layer": "L7_HTTP",
      "matchers": [
        {
          "target": "header",
          "match_type": "regex",
          "value": "^thin ((?:\\d+\\.)*\\d+) codename .+$",
          "confidence_delta": 0.4,
          "field": "server",
          "version_extract": "^thin ((?:\\d+\\.)*\\d+) codename .+$",
          "version_group": 1,
          "case_insensitive": true,
          "note": "Marc-André Cournoyer's thin webserver"
        }
      ],
      "method": "GET",
      "path": "/",
      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "http"
  ],
  "examples": [
    "thin 1.2.4 codename Flaming Astroboy",
    "thin 1 codename Flaming Astroboy"
  ]
}