{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-xlight_ftp_server",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "XLIGHT_FTP_SERVER",
  "taxonomy_name": "Xlight FTP Server",
  "vendor": "Xlight",
  "product": "FTP Server",
  "source": {
    "type": "recog",
    "file": "XLIGHT_FTP_SERVER.json",
    "fingerprint_count": 1
