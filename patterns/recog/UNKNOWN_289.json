{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-unknown",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "UNKNOWN",
  "taxonomy_name": "",
  "vendor": "",
  "product": "",
  "source": {
    "type": "recog",
    "file": "UNKNOWN.json",
    "fingerprint_count": 2
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 2 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    23,
    443,
    8443
  ],
  "probes": [
    {
      "id": "recog_unknown_l4_tcp",
      "layer": "L4_TCP",
      "matchers": [
        {
          "target": "banner",
          "match_type": "regex",
          "value": "(?:RDL-\\d+ Ellipse\\s+|Connect-OWS?) .{0,1000} Copyright .{0,1000} Redline Communications Inc",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "Redline Communication Radios"
        }
      ]
    },
    {
      "id": "recog_unknown_tls_cert",
      "layer": "TLS_CERT",
      "matchers": [
        {
          "target": "tls_subject",
          "match_type": "regex",
          "value": "(?i)CN=(\\w+),OU=BWI,O=Redline Communications Inc",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "Redline Communication Radios"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "telnet",
    "tls"
  ],
  "examples": [
    "RDL-3000 Ellipse     (c) Copyright 2010-2016  Redline Communications Inc.",
    "Connect-OW     (c) Copyright 2010-2016  Redline Communications Inc.",
    "Connect-OWS     (c) Copyright 2010-2016  Redline Communications Inc.",
    "CN=an80i,OU=BWI,O=Redline Communications Inc.,C=CA"
  ]
}