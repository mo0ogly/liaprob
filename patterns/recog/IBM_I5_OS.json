{
  "$schema": "lia-fingerprint-v1",
  "id": "recog-ibm_i5_os",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "IBM_I5_OS",
  "taxonomy_name": "IBM i5/OS",
  "vendor": "IBM",
  "product": "i5/OS",
  "source": {
    "type": "recog",
    "file": "IBM_I5_OS.json",
    "fingerprint_count": 1
  },
  "research": [
    {
      "url": "https://github.com/rapid7/recog",
      "type": "recog_database",
      "evidence": "Converted from 1 Recog XML fingerprints",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    445
  ],
  "probes": [
    {
      "id": "recog_ibm_i5_os_l4_tcp",
      "layer": "L4_TCP",
      "matchers": [
        {
          "target": "banner",
          "match_type": "regex",
          "value": "^I5OS \\D(\\d+)\\D(\\d+)\\D(\\d+)$",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "IBM i5/OS"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "smb"
  ],
  "cpe23_template": "cpe:/o:ibm:i5os:{os.version}",
  "examples": [
    "I5OS V6R1M1"
  ]
}