      "matchers": [
        {
          "target": "banner",
          "match_type": "regex",
          "value": "^Qpopper \\(version (\\d+\\.\\d+\\.\\d+)-mysql-(.+)\\) at (.+) starting\\.",
          "confidence_delta": 0.4,
          "version_extract": "^Qpopper \\(version (\\d+\\.\\d+\\.\\d+)-mysql-(.+)\\) at (.+) starting\\.",
          "version_group": 1,
          "case_insensitive": true,
          "note": "Qpopper with MySQL auth module"
        },
        {
          "target": "banner",
          "match_type": "regex",
          "value": "(?i)^Qpop(?:per)? \\(version ([\\d\\.]+)\\) at (\\S{1,512})(?: starting\\.)?",
          "confidence_delta": 0.4,
          "version_extract": "(?i)^Qpop(?:per)? \\(version ([\\d\\.]+)\\) at (\\S{1,512})(?: starting\\.)?",
          "version_group": 1,
          "case_insensitive": true,
          "note": "Qpopper missing version info"
        },
        {
          "target": "banner",
          "match_type": "regex",
          "value": "^QPOP \\(version (.*)\\) at (.+) starting\\.",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "note": "Qpopper with missing version info"
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
