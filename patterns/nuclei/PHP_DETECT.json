{
  "$schema": "lia-fingerprint-v1",
  "id": "nuclei-php_detect",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "PHP",
  "taxonomy_name": "PHP Detect",
  "source": {
    "type": "nuclei",
    "file": "php-detect.yaml",
    "original_id": "php-detect",
    "parsed_at": "2026-03-17",
    "parser_version": "1.0.0"
  },
  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/http/technologies/php-detect.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template php-detect (MIT)",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "php_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/",
      "matchers": [
        {
          "target": "header",
          "match_type": "contains",
          "value": "PHP",
          "confidence_delta": 0.4,
          "version_extract": "X-Powered-By: PHP/([0-9.]+)",
          "version_group": 1
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "vendor": "Php",
  "product": "Php",
  "cpe23_template": "cpe:2.3:a:php:php:{version}:*:*:*:*:*:*:*",
  "tags": [
    "php"
  ]
}
