        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "bitrix.com",
          "confidence_delta": 0.4,
          "case_insensitive": true
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "bitrixjs",
          "confidence_delta": 0.4,
          "case_insensitive": true
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "X-Powered-By-Bitrix",
          "confidence_delta": 0.4,
          "case_insensitive": true
        }
      ]
    }
  ],
  "base_confidence": 0.0,
