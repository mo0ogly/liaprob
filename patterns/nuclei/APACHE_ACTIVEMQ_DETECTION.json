  "probes": [
    {
      "id": "apache_activ_tcp_0",
      "layer": "L4_TCP",
      "matchers": [
        {
          "target": "banner",
          "match_type": "contains",
          "value": "Unknown STOMP action",
          "confidence_delta": 0.4
