        {
          "target": "banner",
          "match_type": "contains",
          "value": "norg.apache.activemq.transport.stomp",
          "confidence_delta": 0.4
        }
      ],
      "ports": [
        61613
      ],
      "send": "HELP\n\n\u0000"
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "default_ports": [
    61613
  ],
