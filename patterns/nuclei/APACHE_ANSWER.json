  "probes": [
    {
      "id": "apache_answe_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/answer/api/v1/siteinfo",
      "matchers": [
        {
          "target": "body",
          "match_type": "contains",
          "value": "\"code\":",
          "confidence_delta": 0.4,
          "version_extract": "\"version\":\"([^\"]+)\"",
          "version_group": 1
        },
        {
          "target": "header",
          "match_type": "contains",
          "value": "application/json",
          "confidence_delta": 0.4
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "vendor": "Apache",
  "product": "Answer",
  "cpe23_template": "cpe:2.3:a:apache:answer:{version}:*:*:*:*:*:*:*",
  "tags": [
    "apache"
