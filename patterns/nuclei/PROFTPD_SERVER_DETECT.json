      "send": "\n"
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "default_ports": [
    21
  ],
  "tags": [
    "network",
    "ftp",
    "proftpd",
    "tcp"
  ]
