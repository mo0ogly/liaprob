{
  "$schema": "lia-fingerprint-v1",
  "id": "nuclei-fastjson_version_detection",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "FASTJSON",
  "taxonomy_name": "Fastjson Version Detection",
  "source": {
    "type": "nuclei",
    "file": "fastjson-version.yaml",
    "original_id": "fastjson-version",
    "parsed_at": "2026-03-17",
    "parser_version": "1.0.0"
  },
  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/http/technologies/fastjson-version.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template fastjson-version (MIT)",
      "date": "2026-03-17"
    },
    {
      "url": "https://blog.csdn.net/caiqiiqi/article/details/107907489",
      "type": "official_doc",
      "evidence": "Reference from Nuclei template",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "fastjson_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/",
      "matchers": [
        {
          "target": "body",
          "match_type": "contains",
          "value": "fastjson-version",
          "confidence_delta": 0.4,
          "version_extract": "fastjson-version.*([0-9]\\.[0-9]+\\.[0-9]+)",
          "version_group": 1
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "fastjson"
  ]
}
