{
  "$schema": "lia-fingerprint-v1",
  "id": "nuclei-typo3_detection",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "TYPO3",
  "taxonomy_name": "TYPO3 Detection",
  "source": {
    "type": "nuclei",
    "file": "typo3-detect.yaml",
    "original_id": "typo3-detect",
    "parsed_at": "2026-03-17",
    "parser_version": "1.0.0"
  },
  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/http/technologies/typo3-detect.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template typo3-detect (MIT)",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "typo3_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/",
      "matchers": [
        {
          "target": "header",
          "match_type": "contains",
          "value": "X-TYPO3-Parsetime:",
          "confidence_delta": 0.4,
          "case_insensitive": true
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "<meta name=\"generator\" content=\"TYPO3",
          "confidence_delta": 0.4
        }
      ],
      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "vendor": "Typo3",
  "product": "Typo3",
  "cpe23_template": "cpe:2.3:a:typo3:typo3:{version}:*:*:*:*:*:*:*",
  "tags": [
    "typo3"
  ]
}
