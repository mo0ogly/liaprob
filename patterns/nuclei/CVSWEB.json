        {
          "target": "body",
          "match_type": "regex",
          "value": "content=\".*CVSweb.*\"",
          "confidence_delta": 0.4,
          "version_extract": "content=\".*CVSweb\\s*([0-9.]+)\"",
          "version_group": 1
        }
      ],
      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "vendor": "Freebsd",
  "product": "Cvsweb",
  "cpe23_template": "cpe:2.3:a:freebsd:cvsweb:{version}:*:*:*:*:*:*:*",
  "tags": [
