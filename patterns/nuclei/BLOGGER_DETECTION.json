{
  "$schema": "lia-fingerprint-v1",
  "id": "nuclei-blogger_detection",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "BLOGGER",
  "taxonomy_name": "Blogger Detection",
  "source": {
    "type": "nuclei",
    "file": "blogger-detect.yaml",
    "original_id": "blogger-detect",
    "parsed_at": "2026-03-17",
    "parser_version": "1.0.0"
  },
  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/http/technologies/blogger-detect.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template blogger-detect (MIT)",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "blogger_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/",
      "matchers": [
        {
          "target": "body",
          "match_type": "contains",
          "value": "Powered by Blogger",
          "confidence_delta": 0.4,
          "case_insensitive": true
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "blogspot.com",
          "confidence_delta": 0.4,
          "case_insensitive": true
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "X-Powered-By-Blogger",
          "confidence_delta": 0.4,
          "case_insensitive": true
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "blogger.com",
          "confidence_delta": 0.4,
          "case_insensitive": true
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "blogger"
  ]
}
