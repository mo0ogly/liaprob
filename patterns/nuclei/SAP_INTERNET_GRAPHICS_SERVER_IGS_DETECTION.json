{
  "$schema": "lia-fingerprint-v1",
  "id": "nuclei-sap_internet_graphics_server_igs_detection",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "SAP_INTERNET",
  "taxonomy_name": "SAP Internet Graphics Server (IGS) Detection",
  "source": {
    "type": "nuclei",
    "file": "sap-igs-detect.yaml",
    "original_id": "sap-igs-detect",
    "parsed_at": "2026-03-17",
    "parser_version": "1.0.0"
  },
  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/http/technologies/sap-igs-detect.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template sap-igs-detect (MIT)",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "sap_internet_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/",
      "matchers": [
        {
          "target": "header",
          "field": "Server",
          "match_type": "exists",
          "confidence_delta": 0.4,
          "version_extract": "^(.+)$",
          "version_group": 1,
          "note": "kval extractor: Server -> Server"
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "SAP IGS",
          "confidence_delta": 0.2
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "is running",
          "confidence_delta": 0.2
        },
        {
          "target": "header",
          "match_type": "contains",
          "value": "SAP Internet Graphics Server",
          "confidence_delta": 0.4
        }
      ],
      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "sap",
    "igs"
  ]
}
