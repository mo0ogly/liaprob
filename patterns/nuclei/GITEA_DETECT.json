      "type": "official_doc",
      "evidence": "Reference from Nuclei template",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "gitea_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/user/login",
      "matchers": [
        {
          "target": "body",
          "match_type": "contains",
          "value": "Powered by Gitea",
          "confidence_delta": 0.4,
          "version_extract": "Powered by Gitea(\\s*)Version:(\\s*)([\\d.]+)",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "content=\"Gitea",
          "confidence_delta": 0.4,
          "version_extract": "Powered by Gitea(\\s*)Version:(\\s*)([\\d.]+)",
          "version_group": 1
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "gitea"
  ]
}
