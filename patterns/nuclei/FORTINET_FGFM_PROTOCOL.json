      "type": "official_doc",
      "evidence": "Reference from Nuclei template",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "fortinet_fgf_tcp_hex_0",
      "layer": "L4_TCP_HEX",
      "matchers": [
        {
          "target": "banner",
          "match_type": "contains",
          "value": ".fortinet.com",
          "confidence_delta": 0.2,
          "version_extract": "[a-z0-9.-]+\\.fortinet\\.com",
          "version_group": 1
        },
        {
          "target": "banner",
          "match_type": "contains",
          "value": "Certificate Authority",
          "confidence_delta": 0.2,
          "version_extract": "[a-z0-9.-]+\\.fortinet\\.com",
          "version_group": 1
        }
      ],
      "ports": [
        541
      ],
      "send_hex": "2E"
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "default_ports": [
    541
  ],
  "tags": [
    "network",
    "tcp",
    "fortinet",
    "fortigate",
    "fortimanager"
  ]
