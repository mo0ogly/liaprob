          "case_insensitive": true
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "X-Powered-By-osCommerce",
          "confidence_delta": 0.4,
          "case_insensitive": true
        }
      ]
    }
  ],
  "base_confidence": 0.0,
