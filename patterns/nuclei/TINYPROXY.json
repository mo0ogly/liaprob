  "probes": [
    {
      "id": "tinyproxy_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/",
      "matchers": [
        {
          "target": "header",
          "field": "Server",
          "match_type": "exists",
          "confidence_delta": 0.4,
          "version_extract": "^(.+)$",
          "version_group": 1,
          "note": "kval extractor: server -> Server"
        },
        {
          "target": "header",
          "match_type": "contains",
          "value": "server: tinyproxy",
          "confidence_delta": 0.4,
          "case_insensitive": true
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "vendor": "Tinyproxy_Project",
  "product": "Tinyproxy",
  "cpe23_template": "cpe:2.3:a:tinyproxy_project:tinyproxy:{version}:*:*:*:*:*:*:*",
  "tags": [
