  },
  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/http/technologies/tableau-server-detect.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template tableau-server-detect (MIT)",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "salesforce_t_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/",
      "matchers": [
        {
          "target": "header",
          "match_type": "contains",
          "value": "X-Tableau: Tableau Server",
          "confidence_delta": 0.4
        },
        {
          "target": "header",
          "match_type": "contains",
          "value": "Server: Tableau",
          "confidence_delta": 0.4
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "VizPortalRun",
          "confidence_delta": 0.4,
          "version_extract": "data-build[iI]d=\"([0-9a-z_]*)",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "vizportal",
          "confidence_delta": 0.4,
          "version_extract": "data-build[iI]d=\"([0-9a-z_]*)",
          "version_group": 1
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "vendor": "Salesforce",
  "product": "Tableau_Server",
  "tags": [
    "tableau",
    "salesforce"
  ]
