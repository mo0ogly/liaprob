{
  "$schema": "lia-fingerprint-v1",
  "id": "nuclei-neos_cms_detection",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "NEOS_CMS",
  "taxonomy_name": "Neos CMS detection",
  "source": {
    "type": "nuclei",
    "file": "neos-detect.yaml",
    "original_id": "neos-detect",
    "parsed_at": "2026-03-17",
    "parser_version": "1.0.0"
  },
  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/http/technologies/neos-detect.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template neos-detect (MIT)",
      "date": "2026-03-17"
    },
    {
      "url": "https://github.com/neos/",
      "type": "official_doc",
      "evidence": "Reference from Nuclei template",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "neos_cms_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/",
      "matchers": [
        {
          "target": "header",
          "field": "X-Flow-Powered",
          "match_type": "exists",
          "confidence_delta": 0.4,
          "version_extract": "^(.+)$",
          "version_group": 1,
          "note": "kval extractor: x_flow_powered -> X-Flow-Powered"
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "This website is powered by Neos",
          "confidence_delta": 0.4
        }
      ],
      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "neos",
    "cms"
  ]
}
