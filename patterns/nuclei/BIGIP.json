  "probes": [
    {
      "id": "bigip_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/",
      "matchers": [
        {
          "target": "header",
          "match_type": "contains",
          "value": "BIGipServer",
          "confidence_delta": 0.4,
          "version_extract": "(BIGipServer[a-z\\_\\.\\-\\~0-9A-Z]*)=([!a-z0-9A-Z/.=]+)",
          "version_group": 1
        },
        {
          "target": "header",
          "match_type": "contains",
          "value": "BigIP",
          "confidence_delta": 0.4,
          "version_extract": "(BIGipServer[a-z\\_\\.\\-\\~0-9A-Z]*)=([!a-z0-9A-Z/.=]+)",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "F5 Networks.",
          "confidence_delta": 0.4
        }
      ],
      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "bigip",
    "f5"
  ]
}
