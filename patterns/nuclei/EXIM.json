{
  "$schema": "lia-fingerprint-v1",
  "id": "nuclei-exim",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "EXIM",
  "taxonomy_name": "Exim",
  "source": {
    "type": "nuclei",
    "file": "exim-detect.yaml",
    "original_id": "exim-detect",
    "parsed_at": "2026-03-17",
    "parser_version": "1.0.0"
  },
  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/network/detection/exim-detect.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template exim-detect (MIT)",
      "date": "2026-03-17"
    },
    {
      "url": "https://www.exim.org/docs.html",
      "type": "official_doc",
      "evidence": "Reference from Nuclei template",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "exim_tcp_0",
      "layer": "L4_TCP",
      "matchers": [
        {
          "target": "banner",
          "match_type": "contains",
          "value": "ESMTP Exim",
          "confidence_delta": 0.4,
          "version_extract": "(?i)SMTP.Exim\\s?([\\w.]+)",
          "version_group": 1
        }
      ],
      "ports": [
        465,
        587
      ],
      "send": "\n"
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "default_ports": [
    465,
    587
  ],
  "tags": [
    "network",
    "smtp",
    "mail",
    "exim",
    "tcp"
  ]
}
