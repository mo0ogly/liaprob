{
  "$schema": "lia-fingerprint-v1",
  "id": "nuclei-unauthenticated_java_message_broker",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "UNAUTHENTICA",
  "taxonomy_name": "Unauthenticated Java Message Broker",
  "source": {
    "type": "nuclei",
    "file": "unauth-java-message-broker-detect.yaml",
    "original_id": "unauth-java-message-broker-detect",
    "parsed_at": "2026-03-17",
