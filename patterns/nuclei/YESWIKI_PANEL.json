  },
  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/http/technologies/yeswiki-detect.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template yeswiki-detect (MIT)",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "yeswiki_http_0",
      "layer": "L7_HTTP",
