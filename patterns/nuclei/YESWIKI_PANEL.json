      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "vendor": "Yeswiki",
  "product": "Yeswiki",
  "cpe23_template": "cpe:2.3:a:yeswiki:yeswiki:{version}:*:*:*:*:*:*:*",
