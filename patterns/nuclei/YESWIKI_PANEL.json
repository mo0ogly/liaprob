{
  "$schema": "lia-fingerprint-v1",
  "id": "nuclei-yeswiki_panel",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "YESWIKI",
  "taxonomy_name": "YesWiki Panel",
  "source": {
