{
  "$schema": "lia-fingerprint-v1",
  "id": "nuclei-telnet_detection",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "TELNET",
  "taxonomy_name": "Telnet Detection",
  "source": {
    "type": "nuclei",
    "file": "telnet-detect.yaml",
    "original_id": "telnet-detect",
    "parsed_at": "2026-03-17",
    "parser_version": "1.0.0"
  },
  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/network/detection/telnet-detect.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template telnet-detect (MIT)",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "telnet_tcp_0",
      "layer": "L4_TCP",
      "matchers": [
        {
          "target": "banner",
          "match_type": "contains",
          "value": "Telnet",
          "confidence_delta": 0.2
        },
        {
          "target": "banner",
          "match_type": "contains",
          "value": "Login authentication",
          "confidence_delta": 0.2
        }
      ],
      "ports": [
        23
      ],
      "send": "\n"
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "default_ports": [
    23
  ],
  "tags": [
    "network",
    "telnet",
    "tcp"
  ]
}
