{
  "$schema": "lia-fingerprint-v1",
  "id": "nuclei-hugo_detect",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "HUGO",
  "taxonomy_name": "Hugo Detect",
  "source": {
    "type": "nuclei",
    "file": "hugo-detect.yaml",
    "original_id": "hugo-detect",
    "parsed_at": "2026-03-17",
    "parser_version": "1.0.0"
  },
  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/http/technologies/hugo-detect.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template hugo-detect (MIT)",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "hugo_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/",
      "matchers": [
        {
          "target": "body",
          "match_type": "contains",
          "value": "<meta name=generator content=\"Hugo",
          "confidence_delta": 0.4,
          "version_extract": "(?m)<meta name=generator content=\"Hugo ([0-9.]+)\">",
          "version_group": 1
        }
      ],
      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "vendor": "Gohugo",
  "product": "Hugo",
  "cpe23_template": "cpe:2.3:a:gohugo:hugo:{version}:*:*:*:*:*:*:*",
  "tags": [
    "hugo"
  ]
}
