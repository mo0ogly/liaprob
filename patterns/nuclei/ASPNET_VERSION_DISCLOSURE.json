{
  "$schema": "lia-fingerprint-v1",
  "id": "nuclei-aspnet_version_disclosure",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "ASPNET_VERSI",
  "taxonomy_name": "AspNet Version Disclosure",
  "source": {
    "type": "nuclei",
    "file": "aspnet-version-detect.yaml",
    "original_id": "aspnet-version-detect",
    "parsed_at": "2026-03-17",
    "parser_version": "1.0.0"
  },
  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/http/technologies/aspnet-version-detect.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template aspnet-version-detect (MIT)",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "aspnet_versi_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/",
      "matchers": [
        {
          "target": "header",
          "field": "X-Aspnet-Version",
          "match_type": "exists",
          "confidence_delta": 0.4,
          "version_extract": "^(.+)$",
          "version_group": 1,
          "note": "kval extractor: X_AspNet_Version -> X-Aspnet-Version"
        },
        {
          "target": "header",
          "match_type": "regex",
          "value": "(?i)^X-AspNet-Version:\\s*$",
          "confidence_delta": 0.4,
          "negate": true
        }
      ],
      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "aspnet"
  ]
}
