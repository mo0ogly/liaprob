          "confidence_delta": 0.4,
          "version_extract": "<h1>Welcome to (.+)<\\/h1>",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "regex",
          "value": "<title>Welcome to JBoss(.*)</title>",
          "confidence_delta": 0.4,
          "version_extract": "<title>Welcome to JBoss(.*)</title>",
          "version_group": 1
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "jboss"
  ]
