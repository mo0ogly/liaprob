{
  "$schema": "lia-fingerprint-v1",
  "id": "nuclei-caobox_cms",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "CAOBOX_CMS",
  "taxonomy_name": "Caobox CMS",
  "source": {
    "type": "nuclei",
    "file": "caobox-cms-detect.yaml",
    "original_id": "caobox-cms-detect",
    "parsed_at": "2026-03-17",
    "parser_version": "1.0.0"
  },
  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/http/technologies/caobox-cms-detect.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template caobox-cms-detect (MIT)",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "caobox_cms_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/",
      "matchers": [
        {
          "target": "body",
          "match_type": "contains",
          "value": "Caobox CMS",
          "confidence_delta": 0.4
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "powered by Caobox",
          "confidence_delta": 0.4
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "Welcome to Caobox",
          "confidence_delta": 0.4
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "Caobox version",
          "confidence_delta": 0.4
        },
        {
          "target": "body",
          "match_type": "regex",
          "value": "(?i)caobox",
          "confidence_delta": 0.4,
          "version_extract": "(?i)caobox",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "regex",
          "value": "(?i)caobox\\s+(v[0-9.]+)",
          "confidence_delta": 0.4,
          "version_extract": "(?i)caobox\\s+(v[0-9.]+)",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "regex",
          "value": "(?i)<title>Caobox CMS",
          "confidence_delta": 0.4,
          "version_extract": "(?i)<title>Caobox CMS",
          "version_group": 1
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "caobox",
    "cms"
  ]
}
