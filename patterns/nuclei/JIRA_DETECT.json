{
  "$schema": "lia-fingerprint-v1",
  "id": "nuclei-jira_detect",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "JIRA",
  "taxonomy_name": "Jira Detect",
  "source": {
    "type": "nuclei",
    "file": "jira-detect.yaml",
    "original_id": "jira-detect",
    "parsed_at": "2026-03-17",
    "parser_version": "1.0.0"
  },
  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/http/technologies/jira-detect.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template jira-detect (MIT)",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "jira_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/secure/Dashboard.jspa",
      "matchers": [
        {
          "target": "body",
          "match_type": "contains",
          "value": "Project Management Software",
          "confidence_delta": 0.4,
          "version_extract": "title=\"JiraVersion\" value=\"([0-9.]+)",
          "version_group": 1
        }
      ],
      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "vendor": "Atlassian",
  "product": "Jira",
  "cpe23_template": "cpe:2.3:a:atlassian:jira:{version}:*:*:*:*:*:*:*",
  "tags": [
    "panel",
    "jira",
    "atlassian"
  ]
}
