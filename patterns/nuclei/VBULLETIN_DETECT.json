{
  "$schema": "lia-fingerprint-v1",
  "id": "nuclei-vbulletin_detect",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "VBULLETIN",
  "taxonomy_name": "vBulletin Detect",
  "source": {
    "type": "nuclei",
    "file": "vbulletin-detect.yaml",
    "original_id": "vbulletin-detect",
    "parsed_at": "2026-03-17",
    "parser_version": "1.0.0"
  },
  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/http/technologies/vbulletin-detect.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template vbulletin-detect (MIT)",
      "date": "2026-03-17"
    },
    {
      "url": "https://www.vbulletin.com/",
      "type": "official_doc",
      "evidence": "Reference from Nuclei template",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "vbulletin_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/",
      "matchers": [
        {
          "target": "body",
          "match_type": "contains",
          "value": "Powered By vBulletin",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "version_extract": "(?i)meta.name=.generator.*content=.vbulletin.([\\d.|\\d]+)",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "content=\"vBulletin",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "version_extract": "(?i)meta.name=.generator.*content=.vbulletin.([\\d.|\\d]+)",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "id=\"vbulletin_css",
          "confidence_delta": 0.4,
          "case_insensitive": true,
          "version_extract": "(?i)meta.name=.generator.*content=.vbulletin.([\\d.|\\d]+)",
          "version_group": 1
        }
      ],
      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "vendor": "Vbulletin",
  "product": "Vbulletin",
  "cpe23_template": "cpe:2.3:a:vbulletin:vbulletin:{version}:*:*:*:*:*:*:*",
  "tags": [
    "vbulletin"
  ]
}
