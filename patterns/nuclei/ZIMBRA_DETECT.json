  "probes": [
    {
      "id": "zimbra_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/js/zimbraMail/share/model/ZmSettings.js",
      "matchers": [
        {
          "target": "body",
          "match_type": "contains",
          "value": "Zimbra Collaboration Suite Web Client",
          "confidence_delta": 0.4,
          "version_extract": "CLIENT_VERSION\\\",\t\t\t\t\t{type:ZmSetting.T_CONFIG, defaultValue:\\\"(.*?)\"",
          "version_group": 1
        },
        {
          "target": "header",
          "match_type": "contains",
          "value": "application/x-javascript",
          "confidence_delta": 0.4
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "zimbra"
  ]
}
