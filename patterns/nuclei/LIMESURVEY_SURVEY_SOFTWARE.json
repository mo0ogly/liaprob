          "confidence_delta": 0.4,
          "case_insensitive": true
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "alt=\"Powered by LimeSurvey",
          "confidence_delta": 0.4,
          "case_insensitive": true
        }
      ],
      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "vendor": "Limesurvey",
  "product": "Limesurvey",
