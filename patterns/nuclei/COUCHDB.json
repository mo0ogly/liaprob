{
  "$schema": "lia-fingerprint-v1",
  "id": "nuclei-couchdb",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "COUCHDB",
  "taxonomy_name": "CouchDB",
  "source": {
    "type": "nuclei",
    "file": "couchdb-detect.yaml",
    "original_id": "couchdb-detect",
    "parsed_at": "2026-03-17",
    "parser_version": "1.0.0"
  },
  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/http/technologies/couchdb-detect.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template couchdb-detect (MIT)",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "couchdb_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/",
      "matchers": [
        {
          "target": "body",
          "match_type": "contains",
          "value": "\"couchdb\":",
          "confidence_delta": 0.2,
          "version_extract": "\"version\":\"([0-9]+\\.[0-9]+\\.[0-9]+)\"",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "\"vendor\":",
          "confidence_delta": 0.2,
          "version_extract": "\"version\":\"([0-9]+\\.[0-9]+\\.[0-9]+)\"",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "application/json",
          "confidence_delta": 0.4
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "couchdb",
    "db"
  ]
}
