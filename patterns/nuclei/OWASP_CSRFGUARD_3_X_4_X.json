        {
          "target": "body",
          "match_type": "contains",
          "value": "masterTokenValue",
          "confidence_delta": 0.4,
          "version_extract": "(?:masterTokenValue\\s*=\\s*')([^']+)';",
          "version_group": 1
        }
      ]
    }
