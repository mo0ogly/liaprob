  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/http/technologies/openreplay-rum-detect.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template openreplay-rum-detect (MIT)",
