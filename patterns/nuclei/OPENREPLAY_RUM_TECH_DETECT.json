      "date": "2026-03-17"
    },
    {
      "url": "https://docs.openreplay.com/en/sdk/",
      "type": "official_doc",
      "evidence": "Reference from Nuclei template",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "openreplay_r_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/",
      "matchers": [
        {
          "target": "body",
          "match_type": "regex",
          "value": "static\\.openreplay\\.com/(?:latest|[0-9.]+)/openreplay\\.js",
          "confidence_delta": 0.4,
          "version_extract": "static\\.openreplay\\.com/(?:latest|[0-9.]+)/openreplay\\.js",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "regex",
          "value": "projectKey[\"']?\\s*:\\s*[\"'][A-Za-z0-9]{10,}[\"']",
          "confidence_delta": 0.4
        },
        {
          "target": "body",
          "match_type": "regex",
          "value": "ingestPoint[\"']?\\s*:\\s*[\"']https?://[^\"']+/ingest[\"']",
          "confidence_delta": 0.4
        },
        {
          "target": "body",
          "match_type": "regex",
          "value": "[a-z0-9-]+\\.openreplay\\.cloud/ingest",
          "confidence_delta": 0.4
        },
        {
          "target": "body",
          "match_type": "regex",
          "value": "window\\.OpenReplay\\s*=\\s*\\[",
          "confidence_delta": 0.4
        },
        {
          "target": "body",
          "match_type": "regex",
          "value": "openReplay\\s*:\\s*\\{\\s*projectKey",
          "confidence_delta": 0.4
        },
        {
          "target": "body",
          "match_type": "regex",
          "value": "window\\.asayer\\s*=\\s*\\[",
          "confidence_delta": 0.4
        },
        {
          "target": "body",
          "match_type": "regex",
          "value": "asayer\\.io/ingest",
          "confidence_delta": 0.4
        }
      ],
      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "rum",
    "openreplay"
  ]
}
