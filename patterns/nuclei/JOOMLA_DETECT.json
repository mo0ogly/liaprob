{
  "$schema": "lia-fingerprint-v1",
  "id": "nuclei-joomla_detect",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "JOOMLA",
  "taxonomy_name": "Joomla! Detect",
  "source": {
    "type": "nuclei",
    "file": "joomla-detect.yaml",
    "original_id": "joomla-detect",
    "parsed_at": "2026-03-17",
    "parser_version": "1.0.0"
  },
  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/http/technologies/joomla-detect.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template joomla-detect (MIT)",
      "date": "2026-03-17"
    },
    {
      "url": "https://www.joomla.org/",
      "type": "official_doc",
      "evidence": "Reference from Nuclei template",
      "date": "2026-03-17"
    },
    {
      "url": "https://github.com/joomla/joomla-cms",
      "type": "official_doc",
      "evidence": "Reference from Nuclei template",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "joomla_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/administrator/manifests/files/joomla.xml",
      "matchers": [
        {
          "target": "body",
          "match_type": "contains",
          "value": "<version>",
          "confidence_delta": 0.13,
          "version_extract": "<version>(.*?)</version>",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "<creationDate>",
          "confidence_delta": 0.13,
          "version_extract": "<version>(.*?)</version>",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "</metafile>",
          "confidence_delta": 0.13,
          "version_extract": "<version>(.*?)</version>",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "regex",
          "value": "(?:<div[^>]+id=\"wrapper_r\"|<(?:link|script)[^>]+(?:feed|components)/com_|<table[^>]+class=\"pill)",
          "confidence_delta": 0.4,
          "version_extract": "(?:<div[^>]+id=\"wrapper_r\"|<(?:link|script)[^>]+(?:feed|components)/com_|<table[^>]+class=\"pill)",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "regex",
          "value": "(?i)<meta\\s+name=[\"']generator[\"']\\s+content=[\"']\\s*joomla[^\"']*",
          "confidence_delta": 0.4,
          "version_extract": "(?i)<meta\\s+name=[\"']generator[\"']\\s+content=[\"']\\s*joomla[^\"']*",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "regex",
          "value": "(?i)Joomla_([\\d.|\\d]+)_version_history",
          "confidence_delta": 0.4,
          "version_extract": "(?i)Joomla_([\\d.|\\d]+)_version_history",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "regex",
          "value": "FILES_JOOMLA_XML_DESCRIPTION",
          "confidence_delta": 0.4,
          "version_extract": "<version>(.*?)</version>",
          "version_group": 1
        }
      ],
      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "vendor": "Joomla",
  "product": "Joomla\\\\!",
  "cpe23_template": "cpe:2.3:a:joomla:joomla\\\\!:{version}:*:*:*:*:*:*:*",
  "tags": [
    "joomla",
    "cms",
    "oss"
  ]
}
