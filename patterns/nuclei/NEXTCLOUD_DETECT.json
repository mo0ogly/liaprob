  "probes": [
    {
      "id": "nextcloud_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/",
      "matchers": [
        {
          "target": "body",
          "match_type": "contains",
          "value": "var nc_lastLogin",
          "confidence_delta": 0.2,
          "version_extract": "(?m)\"version\":\"([0-9.]+)\",",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "var nc_pageLoad",
          "confidence_delta": 0.2,
          "version_extract": "(?m)\"version\":\"([0-9.]+)\",",
          "version_group": 1
        }
      ],
      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "vendor": "Nextcloud",
  "product": "Nextcloud_Server",
  "cpe23_template": "cpe:2.3:a:nextcloud:nextcloud_server:{version}:*:*:*:*:*:*:*",
  "tags": [
    "nextcloud",
    "storage"
  ]
