  "probes": [
    {
      "id": "vmware_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/",
      "matchers": [
        {
          "target": "body",
          "match_type": "contains",
          "value": "ha-folder-root",
          "confidence_delta": 0.4,
          "version_extract": "<name>(.*?)</name>",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "RetrieveServiceContentResponse",
          "confidence_delta": 0.4,
          "version_extract": "<name>(.*?)</name>",
          "version_group": 1
        },
        {
          "target": "header",
          "match_type": "contains",
          "value": "text/xml",
          "confidence_delta": 0.4
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "vcenter",
    "vmware"
  ]
