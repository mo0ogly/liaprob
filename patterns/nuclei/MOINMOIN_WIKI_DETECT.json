  },
  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/http/technologies/moinmoin-detect.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template moinmoin-detect (MIT)",
