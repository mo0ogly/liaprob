  ],
  "probes": [
    {
      "id": "moinmoin_wik_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/",
      "matchers": [
        {
          "target": "body",
          "match_type": "contains",
          "value": "<a href=\"http://moinmo.in/\" title=\"This site uses the MoinMoin Wiki software.\">MoinMoin Powered</a>",
          "confidence_delta": 0.4,
          "version_extract": "\\/moin_static(\\w+)\\/",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "<a href=\"http://moinmo.in/Python\" title=\"MoinMoin is written in Python.\">Python Powered</a>",
          "confidence_delta": 0.4,
          "version_extract": "\\/moin_static(\\w+)\\/",
          "version_group": 1
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "moin",
    "moinmoin",
    "wiki"
  ]
