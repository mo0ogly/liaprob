{
  "$schema": "lia-fingerprint-v1",
  "id": "nuclei-smtp_detection",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "SMTP",
  "taxonomy_name": "SMTP Detection",
  "source": {
    "type": "nuclei",
    "file": "smtp-detect.yaml",
    "original_id": "smtp-detect",
    "parsed_at": "2026-03-17",
    "parser_version": "1.0.0"
  },
  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/network/detection/smtp-detect.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template smtp-detect (MIT)",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "smtp_tcp_0",
      "layer": "L4_TCP",
      "matchers": [
        {
          "target": "banner",
