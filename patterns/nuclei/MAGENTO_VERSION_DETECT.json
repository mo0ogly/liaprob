{
  "$schema": "lia-fingerprint-v1",
  "id": "nuclei-magento_version_detect",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "MAGENTO",
  "taxonomy_name": "Magento Version Detect",
  "source": {
    "type": "nuclei",
    "file": "magento-version-detect.yaml",
    "original_id": "magento-version-detect",
    "parsed_at": "2026-03-17",
    "parser_version": "1.0.0"
  },
  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/http/technologies/magento-version-detect.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template magento-version-detect (MIT)",
      "date": "2026-03-17"
    },
    {
      "url": "https://www.magento.com/",
      "type": "official_doc",
      "evidence": "Reference from Nuclei template",
      "date": "2026-03-17"
    },
    {
      "url": "https://magento.stackexchange.com/a/62966",
      "type": "official_doc",
      "evidence": "Reference from Nuclei template",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "magento_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/",
      "matchers": [
        {
          "target": "body",
          "match_type": "regex",
          "value": "^Magento/.*$",
          "confidence_delta": 0.4,
          "version_extract": "Magento\\/([0-9.]+) ",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "Copyright (c) 2014 Magento Inc.",
          "confidence_delta": 0.4,
          "version_extract": "Magento\\/([0-9.]+) ",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "Copyright (c) 2013 Magento Inc.",
          "confidence_delta": 0.4,
          "version_extract": "Magento\\/([0-9.]+) ",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "Copyright (c) 2012 Magento Inc.",
          "confidence_delta": 0.4,
          "version_extract": "Magento\\/([0-9.]+) ",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "Copyright (c) 2011 Magento Inc.",
          "confidence_delta": 0.4,
          "version_extract": "Magento\\/([0-9.]+) ",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "Copyright (c) 2010 Magento Inc.",
          "confidence_delta": 0.4,
          "version_extract": "Magento\\/([0-9.]+) ",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "Copyright (c) 2009 Irubin Consulting Inc.",
          "confidence_delta": 0.4,
          "version_extract": "Magento\\/([0-9.]+) ",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "Copyright (c) 2008 Irubin Consulting Inc.",
          "confidence_delta": 0.4,
          "version_extract": "Magento\\/([0-9.]+) ",
          "version_group": 1
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "vendor": "Magento",
  "product": "Magento",
  "cpe23_template": "cpe:2.3:a:magento:magento:{version}:*:*:*:*:*:*:*",
  "tags": [
