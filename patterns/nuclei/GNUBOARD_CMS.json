          "target": "body",
          "match_type": "contains",
          "value": "http://sir.kr",
          "confidence_delta": 0.2,
          "version_extract": "\\( GNU Board (.*) \\)",
          "version_group": 1
        },
        {
          "target": "header",
          "match_type": "contains",
          "value": "text/plain",
          "confidence_delta": 0.4
        }
      ]
    }
  ],
  "base_confidence": 0.0,
