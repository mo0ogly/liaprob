{
  "$schema": "lia-fingerprint-v1",
  "id": "nuclei-owncloud_statuspage_detection",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "OWNCLOUD_STA",
  "taxonomy_name": "Owncloud StatusPage detection",
  "source": {
    "type": "nuclei",
    "file": "nextcloud-owncloud-detect.yaml",
    "original_id": "owncloud-status-page",
    "parsed_at": "2026-03-17",
    "parser_version": "1.0.0"
  },
  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/http/technologies/nextcloud-owncloud-detect.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template owncloud-status-page (MIT)",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "owncloud_sta_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/status.php",
      "matchers": [
        {
          "target": "body",
          "match_type": "contains",
          "value": "\"versionstring\":",
          "confidence_delta": 0.13
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "\"installed\":",
          "confidence_delta": 0.13
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "\"edition\":",
          "confidence_delta": 0.13
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "vendor": "Owncloud",
  "product": "Owncloud",
  "cpe23_template": "cpe:2.3:a:owncloud:owncloud:{version}:*:*:*:*:*:*:*",
  "tags": [
    "owncloud",
    "status"
  ]
}
