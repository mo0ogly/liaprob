  "probes": [
    {
      "id": "strapi_cms_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/admin/init",
      "matchers": [
        {
          "target": "body",
          "match_type": "contains",
          "value": "\"data\"",
          "confidence_delta": 0.13,
          "version_extract": "\"strapiVersion\":\"([0-9.]+)\"",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "\"uuid\"",
          "confidence_delta": 0.13,
          "version_extract": "\"strapiVersion\":\"([0-9.]+)\"",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "\"hasAdmin\"",
          "confidence_delta": 0.13,
          "version_extract": "\"strapiVersion\":\"([0-9.]+)\"",
          "version_group": 1
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "strapi",
    "cms"
