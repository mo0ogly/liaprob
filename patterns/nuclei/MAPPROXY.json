  "probes": [
    {
      "id": "mapproxy_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/",
      "matchers": [
        {
          "target": "body",
          "match_type": "contains",
          "value": "Welcome to MapProxy",
          "confidence_delta": 0.4,
          "version_extract": "MapProxy(?i) ([0-9]+\\.[0-9]+\\.[0-9]+)",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "MapProxy Demo",
          "confidence_delta": 0.4,
          "version_extract": "MapProxy(?i) ([0-9]+\\.[0-9]+\\.[0-9]+)",
          "version_group": 1
        },
        {
          "target": "header",
          "match_type": "contains",
          "value": "text/html",
          "confidence_delta": 0.4
        }
      ],
      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "mapproxy"
