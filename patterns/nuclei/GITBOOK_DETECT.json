{
  "$schema": "lia-fingerprint-v1",
  "id": "nuclei-gitbook_detect",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "GITBOOK",
  "taxonomy_name": "GitBook Detect",
  "source": {
    "type": "nuclei",
    "file": "gitbook-detect.yaml",
    "original_id": "gitbook-detect",
    "parsed_at": "2026-03-17",
    "parser_version": "1.0.0"
  },
  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/http/technologies/gitbook-detect.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template gitbook-detect (MIT)",
      "date": "2026-03-17"
    },
    {
      "url": "https://www.gitbook.com/",
      "type": "official_doc",
      "evidence": "Reference from Nuclei template",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "gitbook_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/",
      "matchers": [
        {
          "target": "body",
          "match_type": "contains",
          "value": "gitbook.page.hasChanged",
          "confidence_delta": 0.2,
          "version_extract": "<meta name=\"generator\" content=\"GitBook ([0-9.]+)\">",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "<meta name=\"generator\" content=\"GitBook",
          "confidence_delta": 0.2,
          "version_extract": "<meta name=\"generator\" content=\"GitBook ([0-9.]+)\">",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "regex",
          "value": "<title>.*[Gg]it[bB]ook</title>",
          "confidence_delta": 0.4,
          "version_extract": "<meta name=\"generator\" content=\"GitBook ([0-9.]+)\">",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "regex",
          "value": "<title>.*· [Gg]it[bB]ook.*</title>",
          "confidence_delta": 0.4,
          "version_extract": "<meta name=\"generator\" content=\"GitBook ([0-9.]+)\">",
          "version_group": 1
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "vendor": "Gitbook",
  "product": "Gitbook",
  "cpe23_template": "cpe:2.3:a:gitbook:gitbook:{version}:*:*:*:*:*:*:*",
  "tags": [
    "gitbook"
  ]
}
