{
  "$schema": "lia-fingerprint-v1",
  "id": "nuclei-wix_detection",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "WIX",
  "taxonomy_name": "Wix Detection",
  "source": {
    "type": "nuclei",
    "file": "Wix-detect.yaml",
    "original_id": "wix-detect",
    "parsed_at": "2026-03-17",
    "parser_version": "1.0.0"
  },
  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/http/technologies/Wix-detect.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template wix-detect (MIT)",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "wix_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/",
      "matchers": [
        {
          "target": "body",
          "match_type": "contains",
          "value": "Powered by Wix",
          "confidence_delta": 0.4,
          "case_insensitive": true
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "X-Wix-Request-Id",
          "confidence_delta": 0.4,
          "case_insensitive": true
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "Wix Static Site",
          "confidence_delta": 0.4,
          "case_insensitive": true
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "wixsite.com",
          "confidence_delta": 0.4,
          "case_insensitive": true
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "wix"
  ]
}
