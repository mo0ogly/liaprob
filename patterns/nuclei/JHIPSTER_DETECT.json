{
  "$schema": "lia-fingerprint-v1",
  "id": "nuclei-jhipster_detect",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "JHIPSTER",
  "taxonomy_name": "JHipster Detect",
  "source": {
    "type": "nuclei",
    "file": "jhipster-detect.yaml",
    "original_id": "jhipster-detect",
    "parsed_at": "2026-03-17",
    "parser_version": "1.0.0"
  },
  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/http/technologies/jhipster-detect.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template jhipster-detect (MIT)",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "jhipster_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/",
      "matchers": [
        {
          "target": "body",
          "match_type": "contains",
          "value": "JHipster",
          "confidence_delta": 0.4
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "@jhipster",
          "confidence_delta": 0.4
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "Welcome, Java Hipster!",
          "confidence_delta": 0.4
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "jhipster-error",
          "confidence_delta": 0.4
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "vendor": "Jhipster",
  "product": "Jhipster",
  "cpe23_template": "cpe:2.3:a:jhipster:jhipster:{version}:*:*:*:*:*:*:*",
  "tags": [
    "jhipster"
  ]
}
