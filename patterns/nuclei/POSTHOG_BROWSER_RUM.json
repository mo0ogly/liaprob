        {
          "target": "body",
          "match_type": "regex",
          "value": "window\\.posthog",
          "confidence_delta": 0.4
        },
        {
          "target": "body",
          "match_type": "regex",
          "value": "api_host[\"']?\\s*:\\s*[\"'][^\"']*posthog",
          "confidence_delta": 0.4
        },
        {
          "target": "body",
          "match_type": "regex",
          "value": "posthog\\.init\\s*\\(",
          "confidence_delta": 0.4,
          "version_extract": "posthog\\.init\\s*\\(",
          "version_group": 1
        }
      ],
      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
