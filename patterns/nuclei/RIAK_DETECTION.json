{
  "$schema": "lia-fingerprint-v1",
  "id": "nuclei-riak_detection",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "RIAK",
  "taxonomy_name": "Riak Detection",
  "source": {
    "type": "nuclei",
    "file": "riak-detect.yaml",
    "original_id": "riak-detect",
    "parsed_at": "2026-03-17",
    "parser_version": "1.0.0"
  },
  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/network/detection/riak-detect.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template riak-detect (MIT)",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "riak_tcp_hex_0",
      "layer": "L4_TCP_HEX",
      "matchers": [
        {
          "target": "banner",
          "match_type": "contains",
          "value": "riak",
          "confidence_delta": 0.4,
          "version_extract": "riak@([0-9.]+)..([0-9.]+([a-z]+[0-9]))",
          "version_group": 1
        }
      ],
      "ports": [
        8087
      ],
      "send_hex": 71
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "default_ports": [
    8087
  ],
  "tags": [
    "network",
    "oss",
    "riak",
    "nosql",
    "tcp"
  ]
}
