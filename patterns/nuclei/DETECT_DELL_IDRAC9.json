  "probes": [
    {
      "id": "detect_dell__http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/sysmgmt/2015/bmc/info",
      "matchers": [
        {
          "target": "body",
          "match_type": "contains",
          "value": "BuildVersion",
          "confidence_delta": 0.4,
          "version_extract": "\"FwVer\" *: *\"([^\"]+)\"",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "SystemModelName",
          "confidence_delta": 0.4,
          "version_extract": "\"FwVer\" *: *\"([^\"]+)\"",
          "version_group": 1
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "dell"
  ]
}
