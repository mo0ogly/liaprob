  "probes": [
    {
      "id": "linkerd_dete_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/",
      "matchers": [
        {
          "target": "header",
          "match_type": "regex",
          "value": "(?mi)^Via\\s*?:.*?linkerd.*$",
          "confidence_delta": 0.4,
          "version_extract": "(?mi)^Via\\s*?:.*?linkerd.*$",
          "version_group": 1
        },
        {
          "target": "header",
          "match_type": "regex",
          "value": "(?mi)^l5d-err:.*$",
          "confidence_delta": 0.4,
          "version_extract": "(?mi)^l5d-err:.*$",
          "version_group": 1
        },
        {
          "target": "header",
          "match_type": "regex",
          "value": "(?mi)^l5d-success-class: 0.*$",
          "confidence_delta": 0.4,
          "version_extract": "(?mi)^l5d-success-class: 0.*$",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "expected but end of input found at",
          "confidence_delta": 0.4
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "linkerd"
  ]
