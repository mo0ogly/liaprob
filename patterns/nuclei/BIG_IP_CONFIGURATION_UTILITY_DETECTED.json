          "confidence_delta": 0.2
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "Configuration Utility",
          "confidence_delta": 0.2
        }
      ]
    },
    {
      "id": "big_ip_confi_http_1",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/mgmt/tm/sys/management-ip",
      "matchers": [
        {
          "target": "header",
          "match_type": "contains",
          "value": "Www-Authenticate: Basic realm",
          "confidence_delta": 0.2
        },
        {
          "target": "header",
          "match_type": "contains",
          "value": "Enterprise Manager",
          "confidence_delta": 0.2
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "check your user-id and password and try again",
          "confidence_delta": 0.4
        }
      ]
    }
