{
  "$schema": "lia-fingerprint-v1",
  "id": "nuclei-influxdb_version_information",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "INFLUXDB_VER",
  "taxonomy_name": "InfluxDB Version Information",
  "source": {
    "type": "nuclei",
    "file": "influxdb-version-detect.yaml",
    "original_id": "influxdb-version-detect",
    "parsed_at": "2026-03-17",
    "parser_version": "1.0.0"
  },
  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/http/technologies/influxdb-version-detect.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template influxdb-version-detect (MIT)",
      "date": "2026-03-17"
    },
    {
      "url": "https://docs.influxdata.com/influxdb/v1.8/tools/api/#ping-http-endpoint",
      "type": "official_doc",
      "evidence": "Reference from Nuclei template",
      "date": "2026-03-17"
    },
    {
      "url": "https://github.com/influxdata/influxdb/blob/master/http/platform_handler.go#L62",
      "type": "official_doc",
      "evidence": "Reference from Nuclei template",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "influxdb_ver_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/",
      "matchers": [
        {
          "target": "header",
          "field": "X-Influxdb-Version",
          "match_type": "exists",
          "confidence_delta": 0.4,
          "version_extract": "^(.+)$",
          "version_group": 1,
          "note": "kval extractor: X_Influxdb_Version -> X-Influxdb-Version"
        },
        {
          "target": "header",
          "match_type": "contains",
          "value": "X-Influxdb-",
          "confidence_delta": 0.4
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "vendor": "Influxdata",
  "product": "Influxdb",
  "cpe23_template": "cpe:2.3:a:influxdata:influxdb:{version}:*:*:*:*:*:*:*",
  "tags": [
    "influxdb",
    "api"
  ]
}
