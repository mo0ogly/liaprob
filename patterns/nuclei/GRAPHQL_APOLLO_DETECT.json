  ],
  "probes": [
    {
      "id": "graphql_apol_http_0",
      "layer": "L7_HTTP",
      "method": "POST",
      "path": "/graphql",
      "matchers": [
        {
          "target": "body",
          "match_type": "contains",
          "value": "Directive \"@skip\" argument \"if\" of type \"Boolean!\" is required, but it was not provided.",
          "confidence_delta": 0.4
        },
        {
          "target": "header",
          "match_type": "contains",
          "value": "Content-Type: text/html",
          "confidence_delta": 0.4,
          "negate": true
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "<html",
          "confidence_delta": 0.4,
          "negate": true
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "<body",
          "confidence_delta": 0.4,
          "negate": true
        }
      ],
      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "graphql",
    "apollo"
  ]
}
