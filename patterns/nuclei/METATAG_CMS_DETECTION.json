        {
          "target": "body",
          "match_type": "regex",
          "value": "(?i)<meta\\s+?name=\"?generator\"?\\s+?content=\"[^\"]+?\"",
          "confidence_delta": 0.4,
          "version_extract": "(?i)<meta\\s+?name=\"?generator\"?\\s+?content=\"[^\"]+?\"",
          "version_group": 1
        }
      ],
      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "cms"
  ]
}
