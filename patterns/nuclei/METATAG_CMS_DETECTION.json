  "probes": [
    {
      "id": "metatag_cms_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/",
      "matchers": [
        {
          "target": "header",
          "match_type": "contains",
          "value": "text/html",
          "confidence_delta": 0.4
