  "probes": [
    {
      "id": "apache_nifi_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/access/config",
      "matchers": [
        {
          "target": "body",
          "match_type": "regex",
          "value": "supportsLogin",
          "confidence_delta": 0.4
        },
        {
          "target": "body",
          "match_type": "regex",
          "value": "disconnectedNodeAcknowledged",
          "confidence_delta": 0.4
        },
        {
          "target": "body",
          "match_type": "regex",
          "value": "(aggregate|node)Snapshots?",
          "confidence_delta": 0.4,
          "version_extract": "(aggregate|node)Snapshots?",
          "version_group": 1
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "apache",
