  "probes": [
    {
      "id": "apache_cocoo_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/",
      "matchers": [
        {
          "target": "header",
          "match_type": "contains",
          "value": "X-Cocoon-Version",
          "confidence_delta": 0.4,
          "version_extract": "X\\-Cocoon\\-Version:([ 0-9.]+)",
          "version_group": 1
        }
      ],
      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "vendor": "Apache",
  "product": "Cocoon",
  "cpe23_template": "cpe:2.3:a:apache:cocoon:{version}:*:*:*:*:*:*:*",
  "tags": [
    "apache",
    "cocoon"
