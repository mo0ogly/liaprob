{
  "$schema": "lia-fingerprint-v1",
  "id": "nuclei-ibm_ftp_cs_service",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "IBM_FTP_CS",
  "taxonomy_name": "IBM FTP CS Service",
  "source": {
    "type": "nuclei",
    "file": "ibm-ftp-detect.yaml",
    "original_id": "ibm-ftp-detect",
    "parsed_at": "2026-03-17",
    "parser_version": "1.0.0"
  },
  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/network/detection/ibm-ftp-detect.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template ibm-ftp-detect (MIT)",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "ibm_ftp_cs_tcp_hex_0",
      "layer": "L4_TCP_HEX",
      "matchers": [
        {
          "target": "banner",
          "match_type": "contains",
          "value": "FTPD1 IBM FTP CS",
          "confidence_delta": 0.4,
          "version_extract": "CS ([A-Z0-9]+)",
          "version_group": 1
        }
      ],
      "ports": [
        21
      ],
      "send_hex": 0
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "default_ports": [
    21
  ],
  "tags": [
    "network",
    "ftp",
    "ibm",
    "tcp"
  ]
}
