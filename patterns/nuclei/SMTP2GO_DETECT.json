{
  "$schema": "lia-fingerprint-v1",
  "id": "nuclei-smtp2go_detect",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "SMTP2GO",
  "taxonomy_name": "SMTP2GO Detect",
  "source": {
    "type": "nuclei",
    "file": "smtp2go-detect.yaml",
    "original_id": "smtp2go-detect",
    "parsed_at": "2026-03-17",
    "parser_version": "1.0.0"
  },
  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/http/technologies/smtp2go-detect.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template smtp2go-detect (MIT)",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "smtp2go_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/",
      "matchers": [
        {
          "target": "body",
          "match_type": "contains",
          "value": "<title>SMTP2GO</title>",
          "confidence_delta": 0.4
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "2022 &copy; SMTP2GO.",
          "confidence_delta": 0.4
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "mailto:ticket@smtp2go.com",
          "confidence_delta": 0.4
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "href=\"https://www.smtp2go.com/\"",
          "confidence_delta": 0.4
        }
      ],
      "follow_redirects": true
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "smtp2go"
  ]
}
