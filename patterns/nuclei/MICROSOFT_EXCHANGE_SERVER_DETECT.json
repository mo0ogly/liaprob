  "probes": [
    {
      "id": "microsoft_ex_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/owa/auth/logon.aspx",
      "matchers": [
        {
          "target": "header",
          "field": "X-Owa-Version",
          "match_type": "exists",
          "confidence_delta": 0.4,
          "version_extract": "^(.+)$",
          "version_group": 1,
          "note": "kval extractor: x_owa_version -> X-Owa-Version"
        },
        {
          "target": "header",
          "match_type": "regex",
          "value": "(?i)(X-Owa-Version:)",
          "confidence_delta": 0.4,
          "version_extract": "(?i)(X-Owa-Version:)",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "regex",
          "value": "/owa/auth/[0-9.]+/",
          "confidence_delta": 0.4,
          "version_extract": "/owa/auth/([0-9.]+)/",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "<title>Exchange Log In</title>",
          "confidence_delta": 0.4,
          "version_extract": "/owa/auth/([0-9.]+)/",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "<title>Microsoft Exchange - Outlook Web Access</title>",
          "confidence_delta": 0.4,
          "version_extract": "/owa/auth/([0-9.]+)/",
          "version_group": 1
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
