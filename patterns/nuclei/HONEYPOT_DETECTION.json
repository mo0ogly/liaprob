{
  "$schema": "lia-fingerprint-v1",
  "id": "nuclei-honeypot_detection",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "HONEYPOT",
  "taxonomy_name": "Honeypot Detection",
  "source": {
    "type": "nuclei",
    "file": "honeypot-detect.yaml",
    "original_id": "honeypot-detect",
    "parsed_at": "2026-03-17",
    "parser_version": "1.0.0"
  },
  "research": [
    {
      "url": "https://github.com/projectdiscovery/nuclei-templates/blob/main/http/technologies/honeypot-detect.yaml",
      "type": "nuclei_template",
      "evidence": "Nuclei template honeypot-detect (MIT)",
      "date": "2026-03-17"
    },
    {
      "url": "https://github.com/zema1/yarx",
      "type": "official_doc",
      "evidence": "Reference from Nuclei template",
      "date": "2026-03-17"
    }
  ],
  "probes": [
    {
      "id": "honeypot_http_0",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/?{{rand1}}=../../../../../../../../etc/passwd&{{rand3}}=1%20and%20updatexml(1,concat(0x7e,(select%20md5({{rand2}}))),1)",
      "matchers": [
        {
          "target": "body",
          "match_type": "regex",
          "value": "root:[x*]:0:0",
          "confidence_delta": 0.4
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "{{md5({{rand2}})}}",
          "confidence_delta": 0.4
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [
    "honeypot",
    "cti"
  ]
}
