          "version_extract": "YOURLS<\\/a>([ a-z0-9.-]+)",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "alt=\"YOURLS",
          "confidence_delta": 0.4,
          "version_extract": "YOURLS<\\/a>([ a-z0-9.-]+)",
          "version_group": 1
        },
        {
          "target": "body",
          "match_type": "contains",
          "value": "/yourls-logo",
          "confidence_delta": 0.4,
          "version_extract": "YOURLS<\\/a>([ a-z0-9.-]+)",
          "version_group": 1
        }
