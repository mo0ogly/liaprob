      "confidence_delta": 0.4,
      "version_group": 1
    },
    {
      "target": "banner",
      "match_type": "regex",
      "value": "^220-FTP Server ready\\r\\n220-Use USER user@host for native FTP proxy\\r\\n220 Your FTP Session will expire after 300 seconds of inactivity\\.\\r\\n",
      "confidence_delta": 0.4
    },
    {
      "target": "banner",
      "match_type": "regex",
      "value": "^220-FTP Server ready\\r\\n220-Welcome to the Sambar FTP Server\\r\\r\\n",
      "confidence_delta": 0.4
    }
  ],
  "service_matchers": [],
  "probes": [
    {
      "id": "nmap_ftp_0",
      "layer": "L4_TCP",
      "send": "",
      "timeout_ms": 3000,
      "matchers": [
        {
          "target": "response",
          "match_type": "regex",
          "value": "^220-Sambar FTP Server Version (\\d\\S+)\\x0d\\x0a",
          "confidence_delta": 0.4,
          "version_group": 1
        },
        {
          "target": "response",
          "match_type": "regex",
          "value": "^220-FTP Server ready\\r\\n220-Use USER user@host for native FTP proxy\\r\\n220 Your FTP Session will expire after 300 seconds of inactivity\\.\\r\\n",
          "confidence_delta": 0.4
        },
        {
          "target": "response",
          "match_type": "regex",
          "value": "^220-FTP Server ready\\r\\n220-Welcome to the Sambar FTP Server\\r\\r\\n",
          "confidence_delta": 0.4
        }
      ],
      "note": "Nmap probe L4_TCP pour ftp"
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.5,
  "tags": [
    "ftp"
  ],
  "notes": "Genere depuis nmap-service-probes. Service: ftp. 3 match(es), 0 softmatch(es). Extraction de version disponible. CPE: cpe:2.3:a:sambar:sambar_server:{version}:*:*:*:*:*:*:*"
