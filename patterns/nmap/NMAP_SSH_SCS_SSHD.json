{
  "$schema": "lia-fingerprint-v1",
  "id": "nmap-ssh-scs-sshd",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_name": "SCS sshd",
  "product": "SCS sshd",
  "source": {
    "type": "nmap",
