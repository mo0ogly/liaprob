  },
  "default_ports": [],
  "cpe23_template": "cpe:2.3:o:compaq:tru64:*:*:*:*:*:*:*:*",
  "banner_matchers": [
    {
      "target": "banner",
      "match_type": "regex",
      "value": "^SSH-([\\d.]+)-([\\d.]+) SSH Secure Shell Tru64 UNIX\\r?\\n",
      "confidence_delta": 0.4,
      "version_group": 2
    },
    {
      "target": "banner",
      "match_type": "regex",
      "value": "^SSH-([\\d.]+)-(\\d+\\.\\d+\\.\\d+) SSH Secure Shell",
      "confidence_delta": 0.4,
      "version_group": 2
    },
    {
      "target": "banner",
      "match_type": "regex",
      "value": "^sshd: SSH Secure Shell (\\d[-.\\w]+) \\(([^\\r\\n\\)]+)\\) on ([-.\\w]+)\\nSSH-(\\d[\\d.]+)-",
      "confidence_delta": 0.4,
      "version_group": 1
    },
    {
      "target": "banner",
      "match_type": "regex",
      "value": "^sshd2\\[\\d+\\]: .*\\r\\nSSH-([\\d.]+)-(\\d[-.\\w]+) SSH Secure Shell \\(([^\\r\\n\\)]+)\\)\\r?\\n",
      "confidence_delta": 0.4,
      "version_group": 2
    },
    {
      "target": "banner",
      "match_type": "regex",
      "value": "^SSH-([\\d.]+)-(\\d+\\.\\d+\\.[-.\\w]+)",
      "confidence_delta": 0.4,
      "version_group": 2
    }
  ],
  "service_matchers": [],
  "probes": [
    {
      "id": "nmap_ssh_0",
      "layer": "L4_TCP",
      "send": "",
      "timeout_ms": 3000,
      "matchers": [
        {
          "target": "response",
          "match_type": "regex",
          "value": "^SSH-([\\d.]+)-([\\d.]+) SSH Secure Shell Tru64 UNIX\\r?\\n",
          "confidence_delta": 0.4,
          "version_group": 2
        },
        {
          "target": "response",
          "match_type": "regex",
          "value": "^SSH-([\\d.]+)-(\\d+\\.\\d+\\.\\d+) SSH Secure Shell",
          "confidence_delta": 0.4,
          "version_group": 2
        },
        {
          "target": "response",
          "match_type": "regex",
          "value": "^sshd: SSH Secure Shell (\\d[-.\\w]+) \\(([^\\r\\n\\)]+)\\) on ([-.\\w]+)\\nSSH-(\\d[\\d.]+)-",
          "confidence_delta": 0.4,
          "version_group": 1
        },
        {
          "target": "response",
          "match_type": "regex",
          "value": "^sshd2\\[\\d+\\]: .*\\r\\nSSH-([\\d.]+)-(\\d[-.\\w]+) SSH Secure Shell \\(([^\\r\\n\\)]+)\\)\\r?\\n",
          "confidence_delta": 0.4,
          "version_group": 2
        },
        {
          "target": "response",
          "match_type": "regex",
          "value": "^SSH-([\\d.]+)-(\\d+\\.\\d+\\.[-.\\w]+)",
          "confidence_delta": 0.4,
          "version_group": 2
        }
      ],
      "note": "Nmap probe L4_TCP pour ssh"
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.5,
  "tags": [
