      "value": "^220 ([-\\w_.]+) Microsoft ESMTP MAIL Service ready at",
      "confidence_delta": 0.4
    },
    {
      "target": "banner",
      "match_type": "regex",
      "value": "^220 Microsoft ESMTP MAIL Service, Version: ([\\w._-]+)\\r\\n",
      "confidence_delta": 0.4,
      "version_group": 1
    },
    {
      "target": "banner",
      "match_type": "regex",
      "value": "^220 ([-.+\\w]+) ESMTP Server \\(Microsoft Exchange Internet Mail Service ([-\\w.]+)\\) ready",
      "confidence_delta": 0.4,
      "version_group": 2
    },
    {
      "target": "banner",
      "match_type": "regex",
      "value": "^220 ([-\\w_.]+) Microsoft Exchange Internet Mail Service ([-\\w_.]+) ready\\r\\n",
      "confidence_delta": 0.4,
      "version_group": 2
    },
    {
      "target": "banner",
      "match_type": "regex",
      "value": "^220 \\+OK Microsoft Exchange SMTP server version ([\\d.]+)",
      "confidence_delta": 0.4,
      "version_group": 1
    },
    {
      "target": "banner",
      "match_type": "regex",
      "value": "^421 [\\d.]+ Service not available, closing transmission channel\\r\\n",
      "confidence_delta": 0.4
    }
  ],
  "service_matchers": [],
  "probes": [
    {
      "id": "nmap_smtp_0",
      "layer": "L4_TCP",
      "send": "",
      "timeout_ms": 3000,
      "matchers": [
        {
          "target": "response",
