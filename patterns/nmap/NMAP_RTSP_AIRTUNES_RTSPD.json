{
  "$schema": "lia-fingerprint-v1",
  "id": "nmap-rtsp-airtunes-rtspd",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_name": "AirTunes rtspd",
  "product": "AirTunes rtspd",
  "source": {
    "type": "nmap",
    "file": "NMAP_RTSP_AIRTUNES_RTSPD.json",
    "origin": "nmap-service-probes",
    "license": "Nmap Public Source License"
  },
  "default_ports": [
    80,
    322,
    554,
    3052,
    3372,
    5000,
    7000,
    7070,
    8080,
    10000
  ],
  "cpe23_template": "cpe:2.3:a:apple:airtunes:{version}:*:*:*:*:*:*:*",
  "banner_matchers": [
    {
      "target": "banner",
      "match_type": "regex",
      "value": "^RTSP/1\\.0 200 OK\\r\\nPublic: ANNOUNCE, SETUP, RECORD, PAUSE, FLUSH, TEARDOWN, OPTIONS, GET_PARAMETER, SET_PARAMETER, POST, GET, PUT\\r\\nServer: AirTunes/([\\w._-]+)\\r\\n\\r\\n",
      "confidence_delta": 0.4,
      "version_group": 1
    },
    {
      "target": "banner",
      "match_type": "regex",
      "value": "^RTSP/1\\.0 403 Forbidden\\r\\nContent-Length: 0\\r\\nServer: AirTunes/([\\d.]+)\\r\\n\\r\\n",
      "confidence_delta": 0.4,
      "version_group": 1
    }
  ],
  "service_matchers": [],
  "probes": [
    {
      "id": "nmap_rtsp_0",
      "layer": "L4_TCP",
      "send": "",
      "timeout_ms": 3000,
      "matchers": [
        {
          "target": "response",
          "match_type": "regex",
          "value": "^RTSP/1\\.0 200 OK\\r\\nPublic: ANNOUNCE, SETUP, RECORD, PAUSE, FLUSH, TEARDOWN, OPTIONS, GET_PARAMETER, SET_PARAMETER, POST, GET, PUT\\r\\nServer: AirTunes/([\\w._-]+)\\r\\n\\r\\n",
          "confidence_delta": 0.4,
          "version_group": 1
        },
        {
          "target": "response",
          "match_type": "regex",
          "value": "^RTSP/1\\.0 403 Forbidden\\r\\nContent-Length: 0\\r\\nServer: AirTunes/([\\d.]+)\\r\\n\\r\\n",
          "confidence_delta": 0.4,
          "version_group": 1
        }
      ],
      "note": "Nmap probe L4_TCP pour rtsp"
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.5,
  "tags": [
    "rtsp"
  ],
  "notes": "Genere depuis nmap-service-probes. Service: rtsp. 2 match(es), 0 softmatch(es). Extraction de version disponible. CPE: cpe:2.3:a:apple:airtunes:{version}:*:*:*:*:*:*:*"
}
