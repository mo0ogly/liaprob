{
  "$schema": "lia-fingerprint-v1",
  "id": "nmap-smtp-barracuda-networks-spam-firewall-smtpd",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_name": "Barracuda Networks Spam Firewall smtpd",
  "product": "Barracuda Networks Spam Firewall smtpd",
  "source": {
    "type": "nmap",
    "file": "NMAP_SMTP_BARRACUDA_NETWORKS_SPAM_FIREWALL_SMTPD.json",
    "origin": "nmap-service-probes",
    "license": "Nmap Public Source License"
  },
  "default_ports": [],
  "cpe23_template": "cpe:2.3:h:barracudanetworks:spam_%26_virus_firewall_600:-:*:*:*:*:*:*:*",
  "banner_matchers": [
    {
      "target": "banner",
      "match_type": "regex",
      "value": "^220 ([-.\\w\\d]+) ESMTP \\([a-fA-F0-9]{32}\\)\\r\\n",
      "confidence_delta": 0.4
    },
    {
      "target": "banner",
      "match_type": "regex",
      "value": "^554 Service unavailable; Client host \\[[\\w._-]+\\] blocked using Barracuda Reputation;",
      "confidence_delta": 0.4
    }
  ],
  "service_matchers": [],
  "probes": [
    {
      "id": "nmap_smtp_0",
      "layer": "L4_TCP",
      "send": "",
      "timeout_ms": 3000,
      "matchers": [
        {
          "target": "response",
          "match_type": "regex",
          "value": "^220 ([-.\\w\\d]+) ESMTP \\([a-fA-F0-9]{32}\\)\\r\\n",
          "confidence_delta": 0.4
        },
        {
          "target": "response",
          "match_type": "regex",
          "value": "^554 Service unavailable; Client host \\[[\\w._-]+\\] blocked using Barracuda Reputation;",
          "confidence_delta": 0.4
        }
      ],
      "note": "Nmap probe L4_TCP pour smtp"
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.5,
  "tags": [
    "smtp"
  ],
  "notes": "Genere depuis nmap-service-probes. Service: smtp. 2 match(es), 0 softmatch(es). CPE: cpe:2.3:h:barracudanetworks:spam_%26_virus_firewall_600:-:*:*:*:*:*:*:*"
}
