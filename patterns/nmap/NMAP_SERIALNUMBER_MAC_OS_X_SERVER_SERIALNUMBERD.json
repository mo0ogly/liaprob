{
  "$schema": "lia-fingerprint-v1",
  "id": "nmap-serialnumber-mac-os-x-server-serialnumberd",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_name": "Mac OS X Server serialnumberd",
  "product": "Mac OS X Server serialnumberd",
  "source": {
    "type": "nmap",
    "file": "NMAP_SERIALNUMBER_MAC_OS_X_SERVER_SERIALNUMBERD.json",
    "origin": "nmap-service-probes",
    "license": "Nmap Public Source License"
  },
  "default_ports": [
    626
  ],
  "cpe23_template": "cpe:2.3:o:apple:mac_os_x:*:*:*:*:*:*:*:*",
  "banner_matchers": [],
  "service_matchers": [],
  "probes": [
    {
      "id": "nmap_serialnumber_0",
      "layer": "L4_UDP",
      "timeout_ms": 3000,
      "matchers": [
        {
          "target": "response",
          "match_type": "regex",
          "value": "^SNRESPS:127\\.0\\.0\\.1:(0x[0-9A-F]{40}):xsvr:(0x[0-9A-F]{40}):(0x[0-9a-f]{8}):(0x[0-9A-F]{40}):127\\.0\\.0\\.1\\0$",
          "confidence_delta": 0.3
        },
        {
          "target": "response",
          "match_type": "regex",
          "value": "^SNRESPS:([\\w._-]+):(0x[0-9A-F]{40}):xsvr:(0x[0-9A-F]{40}):(0x[0-9a-f]{8}):(0x[0-9A-F]{40}):[\\w._-]+\\0$",
          "confidence_delta": 0.3
        }
      ],
      "note": "Nmap probe L4_UDP pour serialnumber"
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.5,
  "tags": [
    "serialnumber"
  ],
  "notes": "Genere depuis nmap-service-probes. Service: serialnumber. 2 match(es), 0 softmatch(es). CPE: cpe:2.3:o:apple:mac_os_x:*:*:*:*:*:*:*:*"
}
