{
  "$schema": "lia-fingerprint-v1",
  "id": "nmap-snmp-snmpv1-server",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_name": "SNMPv1 server",
  "product": "SNMPv1 server",
  "source": {
    "type": "nmap",
    "file": "NMAP_SNMP_SNMPV1_SERVER.json",
    "origin": "nmap-service-probes",
    "license": "Nmap Public Source License"
  },
  "default_ports": [
    161,
    260,
    3401
  ],
  "banner_matchers": [],
  "service_matchers": [],
  "probes": [
    {
      "id": "nmap_snmp_0",
      "layer": "L4_UDP",
      "timeout_ms": 3000,
      "matchers": [
        {
          "target": "response",
          "match_type": "regex",
          "value": "^0.*\\x02\\x01\\0\\x04\\x06public\\xa2.*\\x06\\x08\\+\\x06\\x01\\x02\\x01\\x01\\x05\\0\\x04[^\\0]([^\\0]+)",
          "confidence_delta": 0.4
        },
        {
          "target": "response",
          "match_type": "regex",
          "value": "^0.*\\x02\\x01\\0\\x04\\x06public\\xa2",
          "confidence_delta": 0.4
        }
      ],
      "note": "Nmap probe L4_UDP pour snmp"
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.5,
  "tags": [
    "snmp"
  ],
  "notes": "Genere depuis nmap-service-probes. Service: snmp. 2 match(es), 0 softmatch(es)."
}
