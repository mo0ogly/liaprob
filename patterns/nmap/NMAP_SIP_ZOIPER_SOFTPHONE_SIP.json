{
  "$schema": "lia-fingerprint-v1",
  "id": "nmap-sip-zoiper-softphone-sip",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_name": "Zoiper softphone SIP",
  "product": "Zoiper softphone SIP",
  "source": {
    "type": "nmap",
    "file": "NMAP_SIP_ZOIPER_SOFTPHONE_SIP.json",
    "origin": "nmap-service-probes",
    "license": "Nmap Public Source License"
  },
  "default_ports": [
    5060
  ],
  "cpe23_template": "cpe:2.3:a:securax:zoiper:{version}:*:*:*:*:*:*:*",
  "banner_matchers": [],
  "service_matchers": [],
  "probes": [
    {
      "id": "nmap_sip_0",
      "layer": "L4_UDP",
      "timeout_ms": 3000,
      "matchers": [
        {
          "target": "response",
          "match_type": "regex",
          "value": "^SIP/2\\.0 200 OK\\r\\n(?:[^\\r\\n]+\\r\\n)*?User-Agent: Zoiper rev\\.(\\d+)\\r\\n",
          "confidence_delta": 0.4,
          "version_group": 1
        }
      ],
      "note": "Nmap probe L4_UDP pour sip"
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.5,
  "tags": [
    "sip"
  ],
  "notes": "Genere depuis nmap-service-probes. Service: sip. 1 match(es), 0 softmatch(es). Extraction de version disponible. CPE: cpe:2.3:a:securax:zoiper:{version}:*:*:*:*:*:*:*"
}
