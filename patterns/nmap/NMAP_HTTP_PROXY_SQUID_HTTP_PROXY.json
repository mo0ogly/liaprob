  "probes": [
    {
      "id": "nmap_http-proxy_0",
      "layer": "L7_HTTP",
      "timeout_ms": 3000,
      "matchers": [
        {
          "target": "response",
          "match_type": "regex",
          "value": "^HTTP/1\\.[01] \\d\\d\\d (?:[^\\r\\n]*\\r\\n)*?Server: [sS]quid/([-.\\w+]+)\\r\\n",
          "confidence_delta": 0.5,
          "version_group": 1
        },
