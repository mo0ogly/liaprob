          "confidence_delta": 0.5
        },
        {
          "target": "response",
          "match_type": "regex",
          "value": "^HTTP/1\\.0 400 Cache Detected Error\\r\\nContent-type: text/html\\r\\n\\r\\n.*Generated by squid/([\\w._-]+)@([\\w._-]+)\\n",
          "confidence_delta": 0.5,
          "version_group": 1
        },
        {
          "target": "response",
          "match_type": "regex",
          "value": "^HTTP/1\\.0 400 Bad Request\\r\\nMime-Version: 1\\.0\\r\\n.*<!-- \\n /\\*\\n Stylesheet for Squid Error pages\\n",
          "confidence_delta": 0.5
        },
        {
          "target": "response",
          "match_type": "regex",
          "value": "^HTTP/1\\.1 204 No Content\\r\\n(?:[^\\r\\n]+\\r\\n)*?X-Squid-Error: ERR_INVALID_",
          "confidence_delta": 0.5
        },
        {
          "target": "response",
          "match_type": "regex",
          "value": "^HTTP/1\\.[01] 400 Bad Request\\r\\n(?:[^\\r\\n]+\\r\\n)*?X-Squid-Error: ERR_INVALID_",
          "confidence_delta": 0.5
        },
        {
          "target": "response",
          "match_type": "regex",
          "value": "^HTTP/1\\.0 503 Service Unavailable\\r\\n(?:[^\\r\\n]+\\r\\n)*?X-Squid-Error: ERR_CONNECT_FAIL 111\\r\\n",
          "confidence_delta": 0.5
        },
        {
          "target": "response",
          "match_type": "regex",
          "value": "^HTTP/1\\.1 504 Gateway Time-out\\r\\n(?:[^\\r\\n]+\\r\\n)*?X-Squid-Error: ERR_CONNECT_FAIL 111\\r\\n",
          "confidence_delta": 0.5
        },
        {
          "target": "response",
          "match_type": "regex",
          "value": "^<!DOCTYPE HTML PUBLIC \\\"-//W3C//DTD HTML 4\\.01 Transitional//EN\\\" \\\"http://www\\.w3\\.org/TR/html4/loose\\.dtd\\\">.*ERROR: The requested URL could not be retrieved",
          "confidence_delta": 0.5
