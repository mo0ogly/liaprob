{
  "$schema": "lia-fingerprint-v1",
  "id": "nmap-sip-mitel",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_name": "Mitel",
  "product": "Mitel",
  "source": {
    "type": "nmap",
    "file": "NMAP_SIP_MITEL.json",
    "origin": "nmap-service-probes",
    "license": "Nmap Public Source License"
  },
  "default_ports": [
    5060
  ],
  "banner_matchers": [],
  "service_matchers": [],
  "probes": [
    {
      "id": "nmap_sip_0",
      "layer": "L4_UDP",
      "timeout_ms": 3000,
      "matchers": [
        {
          "target": "response",
          "match_type": "regex",
          "value": "^SIP/2\\.0 403 Forbidden\\r\\n(?:[^\\r\\n]+\\r\\n)*?From: <sip:nm@nm>;tag=root\\r\\nTo: <sip:nm2@nm2>;tag=Mitel-([\\w._-]+)_\\d+-\\d+\\r\\n",
          "confidence_delta": 0.4
        }
      ],
      "note": "Nmap probe L4_UDP pour sip"
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.5,
  "tags": [
    "sip"
  ],
  "notes": "Genere depuis nmap-service-probes. Service: sip. 1 match(es), 0 softmatch(es)."
}
