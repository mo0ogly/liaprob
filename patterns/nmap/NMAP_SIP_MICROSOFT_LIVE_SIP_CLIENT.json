{
  "$schema": "lia-fingerprint-v1",
  "id": "nmap-sip-microsoft-live-sip-client",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_name": "Microsoft Live SIP client",
  "product": "Microsoft Live SIP client",
  "source": {
    "type": "nmap",
    "file": "NMAP_SIP_MICROSOFT_LIVE_SIP_CLIENT.json",
    "origin": "nmap-service-probes",
    "license": "Nmap Public Source License"
  },
  "default_ports": [
    406,
    5060,
    5061,
    8081,
    31337
  ],
  "cpe23_template": "cpe:2.3:o:microsoft:windows:*:*:*:*:*:*:*:*",
  "banner_matchers": [
    {
      "target": "banner",
      "match_type": "regex",
      "value": "^SIP/2\\.0 400 Invalid Contact information\\r\\n.*received=[\\d.]+;ms-received-port=\\d+;ms-received-cid=\\d+\\r\\n",
      "confidence_delta": 0.4
    }
  ],
  "service_matchers": [],
  "probes": [
    {
      "id": "nmap_sip_0",
      "layer": "L4_TCP",
      "send": "",
      "timeout_ms": 3000,
      "matchers": [
        {
          "target": "response",
          "match_type": "regex",
          "value": "^SIP/2\\.0 400 Invalid Contact information\\r\\n.*received=[\\d.]+;ms-received-port=\\d+;ms-received-cid=\\d+\\r\\n",
          "confidence_delta": 0.4
        }
      ],
      "note": "Nmap probe L4_TCP pour sip"
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.5,
  "tags": [
    "sip"
  ],
  "notes": "Genere depuis nmap-service-probes. Service: sip. 1 match(es), 0 softmatch(es). CPE: cpe:2.3:o:microsoft:windows:*:*:*:*:*:*:*:*"
}
