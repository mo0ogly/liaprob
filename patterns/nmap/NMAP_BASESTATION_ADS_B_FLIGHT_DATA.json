{
  "$schema": "lia-fingerprint-v1",
  "id": "nmap-basestation-ads-b-flight-data",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_name": "ADS-B flight data",
  "product": "ADS-B flight data",
  "source": {
    "type": "nmap",
    "file": "NMAP_BASESTATION_ADS_B_FLIGHT_DATA.json",
    "origin": "nmap-service-probes",
    "license": "Nmap Public Source License"
  },
  "default_ports": [],
  "banner_matchers": [
    {
      "target": "banner",
      "match_type": "regex",
      "value": "^(?:MSG|SEL|ID|AIR|STA|CLK)(?:,[^,\\r\\n]*){9,21}\\r\\n",
      "confidence_delta": 0.4
    }
  ],
  "service_matchers": [],
  "probes": [
    {
      "id": "nmap_basestation_0",
      "layer": "L4_TCP",
      "send": "",
      "timeout_ms": 3000,
      "matchers": [
        {
          "target": "response",
          "match_type": "regex",
          "value": "^(?:MSG|SEL|ID|AIR|STA|CLK)(?:,[^,\\r\\n]*){9,21}\\r\\n",
          "confidence_delta": 0.4
        }
      ],
      "note": "Nmap probe L4_TCP pour basestation"
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.5,
  "tags": [
    "basestation"
  ],
  "notes": "Genere depuis nmap-service-probes. Service: basestation. 1 match(es), 0 softmatch(es)."
}
