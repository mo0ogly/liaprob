          "confidence_delta": 0.4,
          "version_group": 2
        },
        {
          "target": "response",
          "match_type": "regex",
          "value": "^SSH-(\\d[\\d.]*)-(Server-V)\\r?\\n$",
          "confidence_delta": 0.4,
          "version_group": 2
