        {
          "target": "response",
          "match_type": "regex",
          "value": "^\\x01\\0.[^\\0].*\\x0c\\0.([\\w-]+)",
          "confidence_delta": 0.3
        },
        {
          "target": "response",
          "match_type": "regex",
          "value": "^\\x01\\0.[^\\0].{48}",
          "confidence_delta": 0.15,
          "note": "softmatch nmap (confidence reduite)"
        },
        {
          "target": "response",
          "match_type": "regex",
          "value": "^\\x02[\\x06\\x09\\x0b].[^\\0].*\\x15\\0.([\\w-]+)\\x16\\0.([\\d.]+)",
          "confidence_delta": 0.3
        },
        {
          "target": "response",
          "match_type": "regex",
          "value": "^\\x02[\\x06\\x09\\x0b].[^\\0].*\\x15\\0.([\\w-]+)",
          "confidence_delta": 0.3
        },
        {
          "target": "response",
          "match_type": "regex",
          "value": "^\\x02[\\x06\\x09\\x0b].[^\\0].{48}",
          "confidence_delta": 0.15,
          "note": "softmatch nmap (confidence reduite)"
