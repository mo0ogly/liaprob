      "confidence_delta": 0.4,
      "version_group": 2
    },
    {
      "target": "banner",
      "match_type": "regex",
      "value": "^220 ([\\w._-]+)[^\\r\\n]*\\r\\n250-[^ ]* \\[[^]]+\\], this server offers \\d+ extensions\\r\\n250",
      "confidence_delta": 0.3
    }
  ],
  "service_matchers": [],
  "probes": [
    {
      "id": "nmap_smtp_0",
      "layer": "L4_TCP",
      "send": "",
      "timeout_ms": 3000,
      "matchers": [
        {
          "target": "response",
          "match_type": "regex",
          "value": "^220 ([\\w._-]+)\\.\\* ESMTP MailEnable Service, Version: ([\\w._-]+)-- ready at \\d\\d/\\d\\d/\\d\\d \\d\\d:\\d\\d:\\d\\d\\r\\n",
          "confidence_delta": 0.4,
          "version_group": 2
        },
        {
          "target": "response",
          "match_type": "regex",
          "value": "^220 ([\\w._-]+)[^\\r\\n]*\\r\\n250-[^ ]* \\[[^]]+\\], this server offers \\d+ extensions\\r\\n250",
          "confidence_delta": 0.3
        }
      ],
      "note": "Nmap probe L4_TCP pour smtp"
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.5,
  "tags": [
    "smtp"
  ],
  "notes": "Genere depuis nmap-service-probes. Service: smtp. 2 match(es), 0 softmatch(es). Extraction de version disponible. CPE: cpe:2.3:a:mailenable:mailenable:{version}:*:*:*:*:*:*:*"
}
