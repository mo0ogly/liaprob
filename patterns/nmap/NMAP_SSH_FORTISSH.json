{
  "$schema": "lia-fingerprint-v1",
  "id": "nmap-ssh-fortissh",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_name": "FortiSSH",
  "product": "FortiSSH",
  "source": {
    "type": "nmap",
    "file": "NMAP_SSH_FORTISSH.json",
    "origin": "nmap-service-probes",
    "license": "Nmap Public Source License"
  },
  "default_ports": [],
  "cpe23_template": "cpe:2.3:o:fortinet:fortios:*:*:*:*:*:*:*:*",
  "banner_matchers": [
    {
      "target": "banner",
      "match_type": "regex",
      "value": "^SSH-([\\d.]+)-FortiSSH_([\\d.]+)\\r?\\n",
      "confidence_delta": 0.4,
      "version_group": 2
    },
    {
      "target": "banner",
      "match_type": "regex",
      "value": "^SSH-([\\d.]+)-.*(?:[a-z](?:[A-Z]\\d|\\d[A-Z])|[A-Z](?:[a-z]\\d|\\d[a-z])|\\d(?:[a-z][A-Z]|[A-Z][a-z]))",
      "confidence_delta": 0.4
    },
    {
      "target": "banner",
      "match_type": "regex",
      "value": "^SSH-([\\d.]+)-.*[b-df-hj-np-tv-xzB-DF-HJ-NP-TV-XZ]{5}",
      "confidence_delta": 0.4
    }
  ],
  "service_matchers": [],
  "probes": [
    {
      "id": "nmap_ssh_0",
      "layer": "L4_TCP",
      "send": "",
      "timeout_ms": 3000,
      "matchers": [
        {
          "target": "response",
          "match_type": "regex",
          "value": "^SSH-([\\d.]+)-FortiSSH_([\\d.]+)\\r?\\n",
          "confidence_delta": 0.4,
          "version_group": 2
        },
        {
          "target": "response",
          "match_type": "regex",
          "value": "^SSH-([\\d.]+)-.*(?:[a-z](?:[A-Z]\\d|\\d[A-Z])|[A-Z](?:[a-z]\\d|\\d[a-z])|\\d(?:[a-z][A-Z]|[A-Z][a-z]))",
          "confidence_delta": 0.4
        },
        {
          "target": "response",
          "match_type": "regex",
          "value": "^SSH-([\\d.]+)-.*[b-df-hj-np-tv-xzB-DF-HJ-NP-TV-XZ]{5}",
          "confidence_delta": 0.4
        }
      ],
      "note": "Nmap probe L4_TCP pour ssh"
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.5,
  "tags": [
    "ssh"
  ],
  "notes": "Genere depuis nmap-service-probes. Service: ssh. 3 match(es), 0 softmatch(es). Extraction de version disponible. CPE: cpe:2.3:o:fortinet:fortios:*:*:*:*:*:*:*:*"
