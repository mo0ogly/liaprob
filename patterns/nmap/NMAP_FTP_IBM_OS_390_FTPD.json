{
  "$schema": "lia-fingerprint-v1",
  "id": "nmap-ftp-ibm-os-390-ftpd",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_name": "IBM OS/390 ftpd",
  "product": "IBM OS/390 ftpd",
  "source": {
    "type": "nmap",
    "file": "NMAP_FTP_IBM_OS_390_FTPD.json",
    "origin": "nmap-service-probes",
    "license": "Nmap Public Source License"
  },
  "default_ports": [],
  "cpe23_template": "cpe:2.3:o:ibm:os_390:*:*:*:*:*:*:*:*",
  "banner_matchers": [
    {
      "target": "banner",
      "match_type": "regex",
      "value": "^220-([-.\\w]+) IBM FTP.*(V\\d+R\\d+)",
      "confidence_delta": 0.4,
      "version_group": 2
    },
    {
      "target": "banner",
      "match_type": "regex",
      "value": "^220-IBM FTP, .*\\.\\r\\n220 Connection will close if idle for more than 120 minutes\\.\\r\\n",
      "confidence_delta": 0.4
    }
  ],
  "service_matchers": [],
  "probes": [
    {
      "id": "nmap_ftp_0",
      "layer": "L4_TCP",
      "send": "",
      "timeout_ms": 3000,
      "matchers": [
        {
          "target": "response",
          "match_type": "regex",
          "value": "^220-([-.\\w]+) IBM FTP.*(V\\d+R\\d+)",
          "confidence_delta": 0.4,
          "version_group": 2
        },
        {
          "target": "response",
          "match_type": "regex",
          "value": "^220-IBM FTP, .*\\.\\r\\n220 Connection will close if idle for more than 120 minutes\\.\\r\\n",
          "confidence_delta": 0.4
        }
      ],
      "note": "Nmap probe L4_TCP pour ftp"
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.5,
  "tags": [
    "ftp"
  ],
  "notes": "Genere depuis nmap-service-probes. Service: ftp. 2 match(es), 0 softmatch(es). Extraction de version disponible. CPE: cpe:2.3:o:ibm:os_390:*:*:*:*:*:*:*:*"
}
