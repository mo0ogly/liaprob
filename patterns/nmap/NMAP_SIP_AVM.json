{
  "$schema": "lia-fingerprint-v1",
  "id": "nmap-sip-avm",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_name": "AVM",
  "product": "AVM",
  "source": {
    "type": "nmap",
    "file": "NMAP_SIP_AVM.json",
    "origin": "nmap-service-probes",
    "license": "Nmap Public Source License"
  },
  "default_ports": [
    5060
  ],
  "cpe23_template": "cpe:2.3:h:avm:$1:*:*:*:*:*:*:*:*",
  "banner_matchers": [],
  "service_matchers": [],
  "probes": [
    {
      "id": "nmap_sip_0",
      "layer": "L4_UDP",
      "timeout_ms": 3000,
      "matchers": [
        {
          "target": "response",
          "match_type": "regex",
          "value": "^SIP/2\\.0 404 Not Found\\r\\n(?:[^\\r\\n]+\\r\\n)*?User-Agent: AVM (FRITZ!Box Fon WLAN [\\w._ -]+) (?:Annex A )?(?:\\(UI\\) )?([\\w._ -]+ \\(\\w+ +\\d+ +\\d+\\))",
          "confidence_delta": 0.4,
          "version_group": 2
        }
      ],
      "note": "Nmap probe L4_UDP pour sip"
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.5,
  "tags": [
    "sip"
  ],
  "notes": "Genere depuis nmap-service-probes. Service: sip. 1 match(es), 0 softmatch(es). Extraction de version disponible. CPE: cpe:2.3:h:avm:$1:*:*:*:*:*:*:*:*"
}
