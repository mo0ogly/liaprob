      "confidence_delta": 0.4
    }
  ],
  "service_matchers": [],
  "probes": [
    {
      "id": "nmap_ftp_0",
      "layer": "L4_TCP",
      "send": "",
      "timeout_ms": 3000,
      "matchers": [
        {
          "target": "response",
          "match_type": "regex",
          "value": "^220-.*\\r\\n(?:220-|)    WarFTPd (\\d[-.\\w]+) \\([\\w ]+\\) Ready\\r\\n",
          "confidence_delta": 0.4,
          "version_group": 1
        },
