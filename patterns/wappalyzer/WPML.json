{
  "$schema": "lia-fingerprint-v1",
  "id": "wappalyzer-wpml",
  "version": "1.0.0",
  "enabled": true,
  "taxonomy_code": "WPML",
  "taxonomy_name": "WPML",
  "vendor": "",
  "product": "WPML",
  "source": {
    "type": "wappalyzer",
    "file": "WPML.json",
    "original_name": "WPML"
  },
  "research": [
    {
      "url": "https://wpml.org/",
      "type": "wappalyzer_database",
      "evidence": "Converted from wappalyzergo fingerprints_data.json",
      "date": "2026-02-28"
    }
  ],
  "default_ports": [
    80,
    443
  ],
  "probes": [
    {
      "id": "wappalyzer_wpml_http",
      "layer": "L7_HTTP",
      "method": "GET",
      "path": "/",
      "follow_redirects": true,
      "matchers": [
        {
          "target": "cookie",
          "field": "wp-wpml_current_language",
          "confidence_delta": 0.5,
          "match_type": "exists"
        },
        {
          "target": "meta",
          "field": "generator",
          "match_type": "regex",
          "value": "^wpml\\sver\\:([\\d\\.]+)",
          "confidence_delta": 0.5,
          "version_extract": "^wpml\\sver\\:([\\d\\.]+)"
        },
        {
          "target": "script_src",
          "match_type": "regex",
          "value": "/wp-content/plugins/sitepress-multilingual-cms/",
          "confidence_delta": 0.5
        }
      ]
    }
  ],
  "base_confidence": 0.0,
  "confidence_threshold": 0.6,
  "tags": [],
  "categories": [
    87,
    89
  ],
  "notes": "WPML plugin makes it possible to build and run fully multilingual WordPress sites.",
  "website": "https://wpml.org/"
}