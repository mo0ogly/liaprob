[
  {
    "id": "lia-nginx",
    "schema": "lia-fingerprint-v1",
    "taxonomy_code": "WEB.NGINX",
    "taxonomy_name": "Nginx",
    "source": "lia",
    "priority": 100,
    "default_ports": [80, 443, 8080, 8443, 18080],
    "probes": [
      {
        "layer": "L7_HTTP",
        "path": "/",
        "method": "GET"
      }
    ],
    "matchers": [
      {
        "field": "http_header.Server",
        "match_type": "contains",
        "value": "nginx",
        "confidence_delta": 0.6
      },
      {
        "field": "http_header.Server",
        "match_type": "regex",
        "value": "nginx/([\\d.]+)",
        "confidence_delta": 0.3,
        "version_group": 1
      }
    ],
    "cpe_template": "cpe:2.3:a:f5:nginx:{version}:*:*:*:*:*:*:*"
  },
