[
  {
    "id": "lia-haproxy",
    "schema": "lia-fingerprint-v1",
    "taxonomy_code": "LB.HAPROXY",
    "taxonomy_name": "HAProxy",
    "source": "lia",
    "priority": 100,
    "default_ports": [80, 443, 8080, 8404],
    "probes": [
      {
        "layer": "L7_HTTP",
        "path": "/",
        "method": "GET"
      }
    ],
    "matchers": [
      {
        "field": "http_header.Server",
        "match_type": "contains",
        "value": "HAProxy",
        "confidence_delta": 0.7
      },
      {
        "field": "http_body",
        "match_type": "contains",
        "value": "HAProxy",
        "confidence_delta": 0.2
      },
      {
        "field": "http_header.Server",
        "match_type": "regex",
        "value": "HAProxy[/ ]([\\d.]+)",
        "confidence_delta": 0.1,
        "version_group": 1
      }
    ],
    "cpe_template": "cpe:2.3:a:haproxy:haproxy:{version}:*:*:*:*:*:*:*"
  },
